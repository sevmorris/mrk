# Logs
*.log
*.log.*

# macOS
.DS_Store

# Dev-only scripts (not distributed)
scripts/clean-test
scripts/dev-test.sh
.AppleDouble
.LSOverride
._*

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*

# Backup directories (if tracked)
backups/

# Temporary files
*.tmp
*.temp
*.bak

# State directories (user-specific)
.mrk/

# Claude Code runtime data
.claude/
dotfiles/.claude/

# Test files
test-*
*.test

# Generated files
.install-manifest
MANIFEST.json

# Browser extension lists (user-specific)
assets/browsers/*-extensions.txt

# Homebrew
Brewfile.lock.json

# Built binaries (platform-specific, built via `make picker` / `make bf` / `make mrk-status` / `make mrk-menu`)
bin/mrk-picker
bin/bf
bin/mrk-status
bin/mrk-menu

# Source-tree build artifacts from `go build` inside tools/<name>/
tools/*/bf
tools/*/mrk-status
tools/*/mrk-picker
tools/*/mrk-menu

# Personal app preferences (captured via `make snapshot-prefs`, stored in ~/.mrk/preferences/)
assets/preferences/*.plist
