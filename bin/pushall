#!/usr/bin/env bash
set -euo pipefail

# pushall — push all git repos in ~/Projects, then sync ~/mrk

PROJECTS_DIR="$HOME/Projects"
MRK_DIR="$HOME/mrk"

ok()   { printf "  [ok] %s\n" "$*"; }
skip() { printf "  [--] %s\n" "$*"; }
fail() { printf "  [!!] %s\n" "$*" >&2; }

overall=0

for repo in "$PROJECTS_DIR"/*/; do
  [[ -d "$repo/.git" ]] || continue

  name="$(basename "$repo")"
  printf "\n%s\n" "$name"

  # Skip if no remote configured
  if ! git -C "$repo" remote | grep -q .; then
    skip "no remote configured"
    continue
  fi

  # Skip if current branch has no upstream
  if ! git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    skip "no upstream tracking branch"
    continue
  fi

  if git -C "$repo" push 2>&1 | sed 's/^/  /'; then
    ok "pushed"
  else
    fail "push failed"
    ((overall++)) || true
  fi
done

if [[ -d "$MRK_DIR/.git" ]]; then
  printf "\nmrk (installed copy)\n"
  if git -C "$MRK_DIR" pull 2>&1 | sed 's/^/  /'; then
    ok "pulled"
  else
    fail "pull failed"
    ((overall++)) || true
  fi
fi

printf "\n"
if (( overall > 0 )); then
  printf "Done — %d repo(s) failed\n" "$overall"
  exit 1
else
  printf "Done\n"
fi
