#!/usr/bin/env bash
set -euo pipefail

# nuke-mrk — Remove all mrk artifacts for a fresh test install
# Moves ~/mrk and ~/.mrk to Trash; removes ~/bin and dotfile symlinks.
# Optionally runs defaults and hardening rollback scripts before cleanup.
# Does NOT uninstall Homebrew packages.

if [[ -t 1 ]]; then
  _B='\033[1m' _D='\033[2m' _R='\033[0m'
  _RED='\033[31m' _GRN='\033[32m' _YLW='\033[33m' _BLU='\033[34m' _CYN='\033[36m'
else
  _B='' _D='' _R='' _RED='' _GRN='' _YLW='' _BLU='' _CYN=''
fi

log()  { printf "${_CYN}[nuke]${_R} %s\n" "$*"; }
ok()   { printf "${_GRN}  ✓${_R} %s\n" "$*"; }
warn() { printf "${_YLW}  ⚠${_R} %s\n" "$*"; }
dim()  { printf "${_D}  · %s${_R}\n" "$*"; }

trash_item() {
  local path="$1" name dest
  name=$(basename "$path")
  dest="$HOME/.Trash/$name"
  [[ -e "$dest" || -L "$dest" ]] && dest="$HOME/.Trash/${name}-$(date +%s)"
  mv "$path" "$dest"
}

MRK_DIR="$HOME/mrk"
STATE_DIR="$HOME/.mrk"
BIN_DIR="$HOME/bin"

printf "\n${_B}${_RED}  ☢  nuke-mrk${_R}\n\n"
printf "  This will move to Trash and remove:\n"
printf "  ${_RED}•${_R} ${_B}$MRK_DIR${_R} ${_D}(cloned repo → Trash)${_R}\n"
printf "  ${_RED}•${_R} ${_B}$STATE_DIR${_R} ${_D}(state/backups/rollback → Trash)${_R}\n"
printf "  ${_RED}•${_R} Symlinks in ${_B}$BIN_DIR${_R} ${_D}pointing to mrk${_R}\n"
printf "  ${_RED}•${_R} Dotfile symlinks in ${_B}$HOME${_R} ${_D}pointing to mrk${_R}\n"
echo ""
printf "  ${_YLW}Does NOT${_R} uninstall Homebrew packages or undo macOS defaults.\n"
echo ""
printf "${_B}Continue? [y/N]:${_R} "
read -r answer
if [[ ! "$answer" =~ ^[Yy]$ ]]; then
  echo "Aborted."
  exit 0
fi

# ── Pre-nuke snapshot ─────────────────────────────────────────────────────────
echo ""
printf "  ${_B}Pre-nuke snapshot${_R}\n\n"
printf "  Sync the Brewfile and snapshot app preferences before wiping.\n"
echo ""
printf "${_B}Run make sync + snapshot-prefs now? [Y/n]:${_R} "
read -r do_snapshot
if [[ ! "$do_snapshot" =~ ^[Nn]$ ]]; then
  if [[ -f "$MRK_DIR/Makefile" ]]; then
    echo ""
    log "Running make sync..."
    if make -C "$MRK_DIR" sync ARGS=-c; then
      ok "Brewfile synced and committed"
    else
      warn "make sync exited with errors"
    fi
    echo ""
    log "Running make snapshot-prefs..."
    if make -C "$MRK_DIR" snapshot-prefs; then
      ok "Preferences snapshotted"
    else
      warn "make snapshot-prefs exited with errors"
    fi
  else
    warn "Makefile not found at $MRK_DIR — skipping"
  fi
else
  dim "Skipping pre-nuke snapshot"
fi

echo ""
# Remove ~/bin symlinks that point into mrk
if [[ -d "$BIN_DIR" ]]; then
  log "Removing mrk symlinks from $BIN_DIR..."
  while read -r link; do
    target=$(readlink "$link" 2>/dev/null || true)
    if [[ "$target" == "$MRK_DIR"/dotfiles/* || \
          "$target" == "$MRK_DIR"/bin/* || \
          "$target" == "$MRK_DIR"/scripts/* ]]; then
      rm -f "$link"
      ok "$(basename "$link")"
    fi
  done < <(find "$BIN_DIR" -maxdepth 1 -type l)
fi

# Remove dotfile symlinks that point into mrk (both hidden and non-hidden)
log "Removing mrk dotfile symlinks from $HOME..."
for f in "$HOME"/.* "$HOME"/*; do
  [[ -L "$f" ]] || continue
  target=$(readlink "$f" 2>/dev/null || true)
  if [[ "$target" == "$MRK_DIR"/dotfiles/* || \
        "$target" == "$MRK_DIR"/bin/* || \
        "$target" == "$MRK_DIR"/scripts/* ]]; then
    rm -f "$f"
    ok "$(basename "$f")"
  fi
done

# Remove topgrade symlink if it points to mrk
topgrade_link="${XDG_CONFIG_HOME:-$HOME/.config}/topgrade.toml"
if [[ -L "$topgrade_link" ]]; then
  target=$(readlink "$topgrade_link" 2>/dev/null || true)
  if [[ "$target" == "$MRK_DIR"/* ]]; then
    rm -f "$topgrade_link"
    ok "topgrade.toml symlink"
  fi
fi

# Remove the pre-mrk topgrade config backup created by post-install
topgrade_bak="$HOME/.config/topgrade.toml.bak"
if [[ -f "$topgrade_bak" ]]; then
  trash_item "$topgrade_bak"
  ok "topgrade.toml.bak (→ Trash)"
fi

# Remove managed browser policy files installed by post-install
for f in "$HOME/Library/Application Support/Google/Chrome/policies/managed/mrk-policy.json" \
         "$HOME/Library/Application Support/BraveSoftware/Brave-Browser/policies/managed/mrk-policy.json"; do
  if [[ -f "$f" ]]; then
    rm -f "$f"
    ok "$(basename "$(dirname "$(dirname "$(dirname "$f")")")") mrk-policy.json"
  fi
done

# Offer to run rollback scripts before trashing state dir
DEFAULTS_ROLLBACK="$STATE_DIR/defaults-rollback.sh"
HARDENING_ROLLBACK="$STATE_DIR/hardening-rollback.sh"
has_rollbacks=0
[[ -f "$DEFAULTS_ROLLBACK" || -f "$HARDENING_ROLLBACK" ]] && has_rollbacks=1

if (( has_rollbacks )); then
  echo ""
  printf "  Rollback scripts found in ${_B}$STATE_DIR${_R}:\n"
  [[ -f "$DEFAULTS_ROLLBACK" ]]  && printf "  ${_YLW}•${_R} defaults-rollback.sh\n"
  [[ -f "$HARDENING_ROLLBACK" ]] && printf "  ${_YLW}•${_R} hardening-rollback.sh\n"
  echo ""
  printf "${_B}Run rollback scripts to undo macOS defaults and hardening? [y/N]:${_R} "
  read -r run_rollbacks
  if [[ "$run_rollbacks" =~ ^[Yy]$ ]]; then
    if [[ -f "$DEFAULTS_ROLLBACK" ]]; then
      log "Running defaults rollback..."
      if bash "$DEFAULTS_ROLLBACK"; then
        ok "Defaults restored"
      else
        warn "defaults-rollback.sh exited with errors"
      fi
    fi
    if [[ -f "$HARDENING_ROLLBACK" ]]; then
      log "Running hardening rollback..."
      if bash "$HARDENING_ROLLBACK"; then
        ok "Hardening undone"
      else
        warn "hardening-rollback.sh exited with errors"
      fi
    fi
  else
    dim "Skipping rollback scripts"
  fi
fi

# Remove state directory
if [[ -d "$STATE_DIR" ]]; then
  log "Moving $STATE_DIR to Trash..."
  trash_item "$STATE_DIR"
  ok "$STATE_DIR"
else
  dim "$STATE_DIR (not found)"
fi

# Remove the update-check cache (written by check-updates)
CACHE_DIR="$HOME/.cache/mrk"
if [[ -d "$CACHE_DIR" ]]; then
  trash_item "$CACHE_DIR"
  ok "$CACHE_DIR"
fi

# Remove cloned repo
if [[ -d "$MRK_DIR" ]]; then
  log "Moving $MRK_DIR to Trash..."
  trash_item "$MRK_DIR"
  ok "$MRK_DIR"
else
  dim "$MRK_DIR (not found)"
fi

# Offer to remove Barkeep (installed by mrk post-install)
if [[ -d "/Applications/Barkeep.app" ]]; then
  echo ""
  printf "${_B}Remove Barkeep.app from /Applications? [y/N]:${_R} "
  read -r remove_barkeep
  if [[ "$remove_barkeep" =~ ^[Yy]$ ]]; then
    log "Removing Barkeep.app..."
    if brew list --cask barkeep &>/dev/null; then
      if brew uninstall --cask barkeep 2>/dev/null; then
        ok "Uninstalled via brew"
      else
        trash_item "/Applications/Barkeep.app"
        ok "Moved /Applications/Barkeep.app to Trash"
      fi
    else
      trash_item "/Applications/Barkeep.app"
      ok "Moved /Applications/Barkeep.app to Trash"
    fi
  else
    dim "Keeping Barkeep.app"
  fi
fi

# Offer to remove oh-my-zsh (installed by make setup's shell phase)
if [[ -d "$HOME/.oh-my-zsh" ]]; then
  echo ""
  printf "${_B}Remove oh-my-zsh (~/.oh-my-zsh)? [y/N]:${_R} "
  read -r remove_omz
  if [[ "$remove_omz" =~ ^[Yy]$ ]]; then
    trash_item "$HOME/.oh-my-zsh"
    ok "$HOME/.oh-my-zsh (→ Trash)"
  else
    dim "Keeping $HOME/.oh-my-zsh"
  fi
fi

# Offer to remove audio-mode / zoom-mode state (written by the standalone
# ~/bin tools, not by the core bootstrap)
audio_zoom_files=(
  "$HOME/.audio_mode_state.json"
  "$HOME/.audio_mode_active"
  "$HOME/.zoom_mode_pids"
  "$HOME/.zoom_mode_active"
  "$HOME/Library/Logs/audio-mode.log"
  "$HOME/Library/Logs/zoom-mode.log"
)
have_audio_zoom=0
for f in "${audio_zoom_files[@]}"; do
  if [[ -e "$f" ]]; then have_audio_zoom=1; break; fi
done
if (( have_audio_zoom )); then
  echo ""
  printf "${_B}Remove audio-mode and zoom-mode state (state files + logs)? [y/N]:${_R} "
  read -r remove_audio_zoom
  if [[ "$remove_audio_zoom" =~ ^[Yy]$ ]]; then
    for f in "${audio_zoom_files[@]}"; do
      if [[ -e "$f" ]]; then
        rm -f "$f"
        ok "$(basename "$f")"
      fi
    done
  else
    dim "Keeping audio-mode/zoom-mode state"
  fi
fi

# Offer to remove the openjdk symlink created by post-install.
# System path — removed explicitly via sudo, never by a general rm block.
JDK_LINK="/Library/Java/JavaVirtualMachines/openjdk.jdk"
if [[ -L "$JDK_LINK" ]]; then
  echo ""
  printf "${_B}Remove openjdk symlink $JDK_LINK? (requires sudo) [y/N]:${_R} "
  read -r remove_jdk
  if [[ "$remove_jdk" =~ ^[Yy]$ ]]; then
    if sudo rm -f "$JDK_LINK"; then
      ok "openjdk.jdk symlink"
    else
      warn "failed to remove $JDK_LINK"
    fi
  else
    dim "Keeping $JDK_LINK"
  fi
fi

# Clean up log files
for f in "$HOME/mrk-install.log" "$HOME/mrk-install.log.old"; do
  if [[ -f "$f" ]]; then
    trash_item "$f"
    ok "$(basename "$f")"
  fi
done

echo ""
printf "${_GRN}${_B}  ✔  Nuked.${_R}\n"
echo ""
printf "  ${_D}Fresh install:${_R}\n"
echo ""
printf "  ${_CYN}git clone https://github.com/sevmorris/mrk.git ~/mrk${_R}\n"
printf "  ${_CYN}make -C ~/mrk all${_R}\n"
echo ""
printf "  ${_D}Then reload your shell:${_R}\n"
echo ""
printf "  ${_CYN}exec zsh${_R}\n"
echo ""
