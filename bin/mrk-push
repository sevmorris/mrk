#!/usr/bin/env bash
set -euo pipefail

# mrk-push — commit, push, and prune all but the current GitHub Deployment
# Usage: mrk-push "commit message"
#        mrk-push            (prompts for message)

if ! command -v gh >/dev/null 2>&1; then
  echo "error: gh CLI not found. Install with: brew install gh" >&2
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "error: Not inside a git repository." >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
# shellcheck source=/dev/null
source "$REPO_ROOT/scripts/lib.sh"

push_log() { log "push: $*"; }

# Commit message
msg="${1:-}"
if [[ -z "$msg" ]]; then
  printf "Commit message: "
  read -r msg < /dev/tty
fi
if [[ -z "$msg" ]]; then
  err "Commit message required."
  exit 1
fi

# Detect GitHub repo (owner/name) from remote
remote_url=$(git remote get-url origin 2>/dev/null || true)
if [[ -z "$remote_url" ]]; then
  err "No 'origin' remote found."
  exit 1
fi
repo=$(echo "$remote_url" \
  | sed 's|git@github.com:||; s|https://github.com/||; s|\.git$||')
if [[ -z "$repo" || "$repo" == "$remote_url" ]]; then
  err "Could not parse GitHub repo from remote: $remote_url"
  exit 1
fi
if [[ ! "$repo" =~ ^[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$ ]]; then
  err "Parsed repo '$repo' does not match expected owner/name format"
  exit 1
fi

echo ""
push_log "Repo: $repo"
echo ""

# ── Commit ────────────────────────────────────────────────────────────────────
push_log "Staging changes..."
# Tracked updates + known repo paths only — never `git add -A`
git add -u
for path in Brewfile Makefile README.md dotfiles scripts bin tools docs assets; do
  [[ -e "$REPO_ROOT/$path" ]] && git add "$REPO_ROOT/$path" 2>/dev/null || true
done

if git diff --cached --quiet; then
  warn "Nothing to commit."
else
  mapfile -t staged_files < <(git diff --cached --name-only --diff-filter=AM)
  if (( ${#staged_files[@]} > 0 )); then
    require_clean_secrets "${staged_files[@]}" || exit 1
  fi
  git commit -m "$msg"
  ok "Committed: $msg"
fi

# ── Push ──────────────────────────────────────────────────────────────────────
push_log "Pushing..."
git push
ok "Pushed to origin."

# ── Prune deployments ─────────────────────────────────────────────────────────
echo ""
push_log "Fetching deployments for $repo..."

if ! mapfile -t ids < <(gh api --paginate "/repos/$repo/deployments" --jq '.[].id' 2>/dev/null); then
  err "Failed to fetch deployments for $repo"
  exit 1
fi

if [[ ${#ids[@]} -eq 0 ]]; then
  warn "No deployments found."
  echo ""
  exit 0
fi

latest="${ids[0]}"
ok "Current deployment: #$latest"

to_delete=("${ids[@]:1}")

if [[ ${#to_delete[@]} -eq 0 ]]; then
  ok "Only one deployment — nothing to prune."
  echo ""
  exit 0
fi

log "Pruning ${#to_delete[@]} older deployment(s)..."
for id in "${to_delete[@]}"; do
  [[ -z "$id" ]] && continue
  # Must be marked inactive before deletion
  gh api -X POST "/repos/$repo/deployments/$id/statuses" \
    -f state=inactive > /dev/null 2>&1 || true
  if gh api -X DELETE "/repos/$repo/deployments/$id" > /dev/null 2>&1; then
    ok "Deleted deployment #$id"
  else
    warn "Could not delete #$id (may already be gone)"
  fi
done

echo ""
ok "Done."
echo ""
