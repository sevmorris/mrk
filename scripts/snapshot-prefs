#!/usr/bin/env bash
set -euo pipefail

# mrk snapshot-prefs — export current app preferences to ~/.mrk/preferences/
# and push to the private mrk-prefs repo.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

: "${PREFS_REPO:=git@github.com:sevmorris/mrk-prefs.git}"
LOCAL_PREFS_DIR="$HOME/.mrk/preferences"
APP_SUPPORT="$HOME/Library/Application Support"

# Apps whose export failed or timed out — reported at exit, never fatal.
SNAPSHOT_SKIPPED=()
report_skipped(){
  if (( ${#SNAPSHOT_SKIPPED[@]} > 0 )); then
    warn "Skipped ${#SNAPSHOT_SKIPPED[@]} app(s) — export failed or timed out: ${SNAPSHOT_SKIPPED[*]}"
  fi
}
trap report_skipped EXIT

# Export a defaults domain with a timeout so a hung or sandboxed domain can't
# stall the whole run. Prefers timeout/gtimeout (coreutils); else background-kill.
defaults_export_timeout(){
  local bundle_id="$1" out="$2" secs="${3:-15}"
  if command -v timeout >/dev/null 2>&1; then
    timeout "$secs" defaults export "$bundle_id" "$out"
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout "$secs" defaults export "$bundle_id" "$out"
  else
    defaults export "$bundle_id" "$out" &
    local pid=$! rc=0
    ( sleep "$secs"; kill "$pid" 2>/dev/null ) &
    local killer=$!
    wait "$pid" 2>/dev/null || rc=$?
    kill "$killer" 2>/dev/null || true
    return "$rc"
  fi
}

# Ensure the local prefs dir is a git repo pointing at mrk-prefs
if [[ ! -d "$LOCAL_PREFS_DIR/.git" ]]; then
  if [[ -d "$LOCAL_PREFS_DIR" ]]; then
    log "Initialising git repo in existing directory: $LOCAL_PREFS_DIR"
    git -C "$LOCAL_PREFS_DIR" init
    git -C "$LOCAL_PREFS_DIR" remote add origin "$PREFS_REPO"
  else
    log "Cloning $PREFS_REPO → $LOCAL_PREFS_DIR"
    git clone "$PREFS_REPO" "$LOCAL_PREFS_DIR"
  fi
fi

# ── Plist exports (defaults export) ──────────────────────────────────────────

snapshot_plist(){
  local bundle_id="$1" filename="$2" app_path="$3" name="$4"
  if [[ ! -d "$app_path" ]]; then
    log "Skipping $name (not installed)"
    return 0
  fi
  if ! defaults_export_timeout "$bundle_id" "$LOCAL_PREFS_DIR/$filename"; then
    warn "failed to export $name — skipped"
    SNAPSHOT_SKIPPED+=("$name")
    return 0
  fi
  # Convert to xml1 (as bin/snapshot does) so the secret scan reads text,
  # not binary plist data.
  if ! plutil -convert xml1 "$LOCAL_PREFS_DIR/$filename" 2>/dev/null; then
    warn "failed to convert $name export to xml1 — skipped"
    SNAPSHOT_SKIPPED+=("$name")
    return 0
  fi
  if ! scan_for_secrets "$LOCAL_PREFS_DIR/$filename"; then
    warn "$name export may contain secrets — review before pushing"
  fi
  log "Saved $name → $LOCAL_PREFS_DIR/$filename"
}

# Previously captured
snapshot_plist "com.hegenberg.BetterSnapTool"           "BetterSnapTool.plist"    "/Applications/BetterSnapTool.app"   "BetterSnapTool"
snapshot_plist "com.jordanbaird.Ice"                    "Ice.plist"               "/Applications/Ice.app"              "Ice"
snapshot_plist "com.googlecode.iterm2"                  "iTerm2.plist"            "/Applications/iTerm.app"            "iTerm2"

# Newly added
snapshot_plist "com.raycast.macos"                      "Raycast.plist"           "/Applications/Raycast.app"          "Raycast"
snapshot_plist "eu.exelban.Stats"                       "Stats.plist"             "/Applications/Stats.app"            "Stats"
snapshot_plist "com.rogueamoeba.Loopback"               "Loopback.plist"          "/Applications/Loopback.app"         "Loopback"
snapshot_plist "com.rogueamoeba.soundsource"            "SoundSource.plist"       "/Applications/SoundSource.app"      "SoundSource"
snapshot_plist "com.rogueamoeba.audiohijack"            "AudioHijack.plist"       "/Applications/Audio Hijack.app"     "Audio Hijack"
snapshot_plist "com.rogueamoeba.farrago"                "Farrago.plist"           "/Applications/Farrago.app"          "Farrago"
snapshot_plist "com.rogueamoeba.Piezo"                  "Piezo.plist"             "/Applications/Piezo.app"            "Piezo"
snapshot_plist "abnerworks.Typora"                      "Typora.plist"            "/Applications/Typora.app"           "Typora"
snapshot_plist "com.aone.keka"                          "Keka.plist"              "/Applications/Keka.app"             "Keka"
snapshot_plist "com.tclementdev.timemachineeditor.application" "TimeMachineEditor.plist" "/Applications/TimeMachineEditor.app" "TimeMachineEditor"
snapshot_plist "com.goodsnooze.MacWhisper"              "MacWhisper.plist"        "/Applications/MacWhisper.app"       "MacWhisper"

# ── Application Support files ─────────────────────────────────────────────────

snapshot_app_support(){
  local app_name="$1" dest_subdir="$2"
  shift 2
  local files=("$@")
  local src_dir="$APP_SUPPORT/$app_name"
  local dest_dir="$LOCAL_PREFS_DIR/app-support/$dest_subdir"

  if [[ ! -d "$src_dir" ]]; then
    log "Skipping $app_name app support (directory not found)"
    return 0
  fi

  mkdir -p "$dest_dir"
  local saved=0
  for file in "${files[@]}"; do
    if [[ -f "$src_dir/$file" ]]; then
      cp "$src_dir/$file" "$dest_dir/$file"
      if ! scan_for_secrets "$dest_dir/$file"; then
        warn "$app_name/$file may contain secrets — review before pushing"
      fi
      saved=$(( saved + 1 ))
    fi
  done
  log "Saved $app_name app support ($saved file(s)) → $dest_dir"
}

# Loopback routing configurations
snapshot_app_support "Loopback" "Loopback" \
  "Devices.plist" "RecentApps.plist"

# SoundSource device presets and routing
snapshot_app_support "SoundSource" "SoundSource" \
  "Presets.plist" "CustomPresets.plist" "Sources.plist" "Models.plist"

# ── Preference directories (file trees, not defaults domains) ─────────────────

# Some apps store configuration as a tree of files under ~/Library/Preferences/
# rather than as a defaults domain, so `defaults export` captures nothing useful.
# Copy selected top-level globs and/or subdirectories verbatim into config/, then
# secret-scan each copied file. The dest is cleared first so files removed from
# the source (e.g. uninstalled plugins) don't linger in the backup.
snapshot_pref_dir(){
  local src_dir="$1" dest_subdir="$2" name="$3"
  shift 3
  local includes=("$@")

  [[ -n "$dest_subdir" ]] || { warn "snapshot_pref_dir: empty dest_subdir for $name"; return 0; }
  if [[ ! -d "$src_dir" ]]; then
    log "Skipping $name (config dir not found: $src_dir)"
    return 0
  fi

  local dest_dir="$LOCAL_PREFS_DIR/config/$dest_subdir"
  rm -rf "$dest_dir"
  mkdir -p "$dest_dir"

  local item path rel saved=0
  for item in "${includes[@]}"; do
    shopt -s nullglob
    # Intentional glob: $item is a pattern (e.g. *.json) or a literal subdir name.
    # shellcheck disable=SC2206
    local matches=( "$src_dir"/$item )
    shopt -u nullglob
    for path in "${matches[@]}"; do
      [[ -e "$path" ]] || continue
      rel="${path#"$src_dir"/}"
      mkdir -p "$dest_dir/$(dirname "$rel")"
      cp -R "$path" "$dest_dir/$rel"
      saved=$(( saved + 1 ))
    done
  done

  # Plugin/config files may carry tokens — scan everything that was copied.
  local f
  while IFS= read -r -d '' f; do
    if ! scan_for_secrets "$f"; then
      warn "$name/${f#"$dest_dir"/} may contain secrets — review before pushing"
    fi
  done < <(find "$dest_dir" -type f -print0 2>/dev/null)

  log "Saved $name config ($saved item(s)) → $dest_dir"
}

# Calibre stores settings as JSON/plist files plus conversion presets and
# installed plugins under ~/Library/Preferences/calibre/ (not a defaults domain).
snapshot_pref_dir "$HOME/Library/Preferences/calibre" "calibre" "Calibre" \
  "*.json" "*.plist" "conversion" "plugins"

# ── Commit and push ───────────────────────────────────────────────────────────

cd "$LOCAL_PREFS_DIR"

# Stage only snapshot outputs — never `git add .`
shopt -s nullglob
stage_files=( *.plist )
shopt -u nullglob
for tree in app-support config; do
  if [[ -d "$tree" ]]; then
    while IFS= read -r -d '' f; do
      stage_files+=("$f")
    done < <(find "$tree" -type f -print0 2>/dev/null)
  fi
done

if (( ${#stage_files[@]} == 0 )); then
  log "No preference files to stage."
  exit 0
fi

git add -- "${stage_files[@]}"

if git diff --cached --quiet; then
  log "No changes to push."
  exit 0
fi

# Scan staged snapshot files before commit/push
mapfile -t changed_files < <(git diff --cached --name-only --diff-filter=AM)
require_clean_secrets "${changed_files[@]}" || exit 1

git commit -m "snapshot: $(date '+%Y-%m-%d %H:%M')"
# -u origin HEAD: the init path (git init + remote add) has no upstream yet;
# on the clone path this is equivalent to a plain push.
git push -u origin HEAD
ok "Pushed to $PREFS_REPO"
