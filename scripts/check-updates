#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

# mrk weekly update checker
# Runs silently unless updates are available.
# Zero blocking network I/O on shell startup — compares against the last
# fetched remote, then refreshes origin in a disowned background fetch.

# Configuration
CACHE_DIR="${HOME}/.cache/mrk"
TIMESTAMP_FILE="${CACHE_DIR}/last-update-check"
CHECK_INTERVAL_DAYS=7

# Resolve symlinks so this works when called via ~/bin symlink
_resolve_self() {
  local target="$1"
  while [[ -L "$target" ]]; do
    local dir; dir="$(cd "$(dirname "$target")" && pwd)"
    target="$(readlink "$target")"
    [[ "$target" != /* ]] && target="$dir/$target"
  done
  cd "$(dirname "$target")" && pwd
}
REPO_DIR="${REPO_DIR:-$(_resolve_self "${BASH_SOURCE[0]}")/..}"
REPO_DIR="$(cd "$REPO_DIR" && pwd)"

# Exit silently if not in an interactive shell
[[ -t 0 ]] || exit 0

mkdir -p "$CACHE_DIR"

# Check if enough time has passed since last check
if [[ -f "$TIMESTAMP_FILE" ]]; then
  last_check=$(cat "$TIMESTAMP_FILE" 2>/dev/null || echo 0)
  now=$(date +%s)
  elapsed_days=$(( (now - last_check) / 86400 ))
  if (( elapsed_days < CHECK_INTERVAL_DAYS )); then
    exit 0
  fi
fi

# Verify repo directory exists and is a git repo
if [[ ! -d "$REPO_DIR/.git" ]]; then
  exit 0
fi

# Rate-limit before compare so new shells don't re-enter this week
date +%s > "$TIMESTAMP_FILE"

# Detect default branch name
default_branch=$(git -C "$REPO_DIR" rev-parse --abbrev-ref origin/HEAD 2>/dev/null | cut -d'/' -f2)
default_branch="${default_branch:-main}"

# Compare local HEAD with last fetched remote (no blocking fetch)
local_head=$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null) || exit 0
remote_head=$(git -C "$REPO_DIR" rev-parse "origin/$default_branch" 2>/dev/null) || {
  # No remote ref yet — kick off a background fetch for next week's check
  { git -C "$REPO_DIR" fetch --quiet 2>/dev/null || true; } & disown
  exit 0
}

if [[ "$local_head" == "$remote_head" ]]; then
  { git -C "$REPO_DIR" fetch --quiet 2>/dev/null || true; } & disown
  exit 0
fi

# Local has diverged or is ahead; don't prompt
if ! git -C "$REPO_DIR" merge-base --is-ancestor "$local_head" "$remote_head" 2>/dev/null; then
  { git -C "$REPO_DIR" fetch --quiet 2>/dev/null || true; } & disown
  exit 0
fi

# Prompt user for update
printf '\033[33mmrk updates available.\033[0m Update now? [y/N] '
read -r response </dev/tty
case "$response" in
  [yY]|[yY][eE][sS])
    make -C "$REPO_DIR" update
    ;;
esac

# Refresh remote refs for next session (non-blocking)
{ git -C "$REPO_DIR" fetch --quiet 2>/dev/null || true; } & disown
