#!/usr/bin/env bash
# adventure-prologue — interactive fiction prelude for mrk adventure mode
#
# A SunOS workstation at UC Berkeley, circa 1989.
# A floppy disk is already mounted at /mnt/floppy.
# Find the setup script and run it.
#
# Exits 0 on success (setup run), 1 if the user quits.
# Skips silently if stdin or stdout is not a terminal.

set -uo pipefail

# ── Skip if not interactive ──────────────────────────────────────────────────
if [[ ! -t 0 ]] || [[ ! -t 1 ]]; then
  exit 0
fi

# ── Colors: phosphor amber on black ─────────────────────────────────────────
_G=$'\033[38;5;214m'    # amber        — terminal output
_BG=$'\033[1;38;5;214m' # bright amber — prompts, borders
_DG=$'\033[2;38;5;214m' # dim amber    — system messages, hints
_R=$'\033[0m'           # reset
_CLR=$'\033[2J\033[H'

g()    { printf '%s%s%s\n' "$_G"  "$*" "$_R"; }
dg()   { printf '%s%s%s\n' "$_DG" "$*" "$_R"; }
blank(){ printf '\n'; }
ll()   { sleep "${2:-0.08}";  g  "$1"; }
lld()  { sleep "${2:-0.08}"; dg  "$1"; }
say()  { local w; w=$(( $(tput cols) - 2 )); (( w < 20 )) && w=20
         while IFS= read -r _l; do printf '%s%s%s\n' "$_G" "$_l" "$_R"
         done < <(printf '%s\n' "$*" | fold -s -w "$w"); }

# ── TUI: fixed screen panel ──────────────────────────────────────────────────
SCREEN_HEIGHT=20

tui_init() {
  local lines cols
  lines=$(tput lines)
  cols=$(tput cols)
  tput csr "$SCREEN_HEIGHT" "$((lines - 1))"
  draw_screen
  tput cup "$SCREEN_HEIGHT" 0
}

tui_cleanup() {
  tput csr 0 "$(($(tput lines) - 1))"
  tput cnorm
  printf '%s' "$_CLR"
}

tui_resize() {
  local lines
  lines=$(tput lines)
  tput csr "$SCREEN_HEIGHT" "$((lines - 1))"
  draw_screen
}

draw_screen() {
  local cols inner
  cols=$(tput cols)
  (( cols < 60 )) && return
  inner=$((cols - 2))

  local N=$((inner - 6))
  local C=$((inner - 8))
  (( C < 10 )) && return

  local R=$((cols - 1))

  # ── Panel content ────────────────────────────────────────────────────────
  local cwd_display="$CWD"
  [[ "$cwd_display" == "/home/mrk" ]] && cwd_display="~"

  local h1 h2 h3
  printf -v h1 "%-${inner}s" "  UNIVERSITY OF CALIFORNIA, BERKELEY  --  CSUA"
  h1="${h1:0:$inner}"

  local hn="  soda.csua.berkeley.edu" sh_str="csh"
  local hgap=$(( inner - ${#hn} - ${#sh_str} ))
  (( hgap < 1 )) && hgap=1
  printf -v h2 "%-${inner}s" "$(printf '%s%*s%s' "$hn" "$hgap" "" "$sh_str")"
  h2="${h2:0:$inner}"

  local pw="  [o PWR]" rm_id="SODA HALL"
  local pgap=$(( inner - ${#pw} - ${#rm_id} ))
  (( pgap < 1 )) && pgap=1
  printf -v h3 "%-${inner}s" "$(printf '%s%*s%s' "$pw" "$pgap" "" "$rm_id")"
  h3="${h3:0:$inner}"

  local sblank sdist sver sstatus sinv
  printf -v sblank  "%-${C}s" ""
  printf -v sdist   "%-${C}s" " soda.csua.berkeley.edu  --  4.3BSD"
  printf -v sver    "%-${C}s" " CSUA  --  Univ. of California, Berkeley"

  local ul=" USER: mrk" dr="DISK: /mnt/floppy [mounted]"
  local ugap=$(( C - ${#ul} - ${#dr} ))
  (( ugap < 1 )) && ugap=1
  printf -v sstatus "%-${C}s" "$(printf '%s%*s%s' "$ul" "$ugap" "" "$dr")"
  sstatus="${sstatus:0:$C}"

  printf -v sinv "%-${C}s" " PATH: $cwd_display"
  sinv="${sinv:0:$C}"

  local obrd nbrd
  printf -v obrd '%*s' "$inner" ''; obrd="${obrd// /─}"
  printf -v nbrd '%*s' "$N"     ''; nbrd="${nbrd// /─}"

  # ── Draw ─────────────────────────────────────────────────────────────────
  tput sc
  tput civis

  tput cup  0 0;  printf '%s┌%s'            "$_BG" "$obrd"
  tput cup  0 $R; printf '%s┐%s'            "$_BG" "$_R"

  tput cup  1 0;  printf '%s│%s%s'          "$_BG" "$_G"  "$h1"
  tput cup  1 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup  2 0;  printf '%s│%s%s'          "$_BG" "$_DG" "$h2"
  tput cup  2 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup  3 0;  printf '%s├%s'            "$_BG" "$obrd"
  tput cup  3 $R; printf '%s┤%s'            "$_BG" "$_R"

  tput cup  4 0;  printf '%s│%s  ┌%s┐  '   "$_BG" "$_G"  "$nbrd"
  tput cup  4 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup  5 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sblank"
  tput cup  5 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup  6 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sdist"
  tput cup  6 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup  7 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sver"
  tput cup  7 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup  8 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sblank"
  tput cup  8 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup  9 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sblank"
  tput cup  9 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 10 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sstatus"
  tput cup 10 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 11 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sinv"
  tput cup 11 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 12 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sblank"
  tput cup 12 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 13 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sblank"
  tput cup 13 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 14 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sblank"
  tput cup 14 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 15 0;  printf '%s│%s  │ %s │  ' "$_BG" "$_G"  "$sblank"
  tput cup 15 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 16 0;  printf '%s│%s  └%s┘  '   "$_BG" "$_G"  "$nbrd"
  tput cup 16 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 17 0;  printf '%s├%s'            "$_BG" "$obrd"
  tput cup 17 $R; printf '%s┤%s'            "$_BG" "$_R"

  tput cup 18 0;  printf '%s│%s%s'          "$_BG" "$_DG" "$h3"
  tput cup 18 $R; printf '%s│%s'            "$_BG" "$_R"

  tput cup 19 0;  printf '%s└%s'            "$_BG" "$obrd"
  tput cup 19 $R; printf '%s┘%s'            "$_BG" "$_R"

  tput cnorm
  tput rc
}

# ── SIGINT: clean exit ───────────────────────────────────────────────────────
trap 'blank; dg "Connection closed."; blank; tui_cleanup; exit 1' INT TERM

# ── World state ──────────────────────────────────────────────────────────────
CWD="/home/mrk"

# ── Resolve a path relative to CWD ──────────────────────────────────────────
resolve_path() {
  local arg="${1:-}"
  [[ -z "$arg" || "$arg" == "." ]] && { printf '%s' "$CWD"; return; }
  [[ "$arg" == "~" ]]              && { printf '%s' "/home/mrk"; return; }
  [[ "$arg" == /* ]]               && { printf '%s' "$arg"; return; }
  if [[ "$arg" == ".." ]]; then
    case "$CWD" in
      /home/mrk)   printf '%s' "/home"  ;;
      /home)       printf '%s' "/"      ;;
      /mnt/floppy) printf '%s' "/mnt"   ;;
      /mnt)        printf '%s' "/"      ;;
      *)           printf '%s' "/"      ;;
    esac
    return
  fi
  printf '%s' "$CWD/$arg"
}

# ── Virtual filesystem ───────────────────────────────────────────────────────
list_dir() {
  local path="${1%/}"
  [[ -z "$path" ]] && path="/"
  case "$path" in
    /)
      g "total 8"
      g "drwxr-xr-x   5 root     wheel        160 Sep 28 12:00 ."
      g "drwxr-xr-x   5 root     wheel        160 Sep 28 12:00 .."
      g "drwxr-xr-x   3 root     wheel         60 Sep 28 12:00 home"
      g "drwxr-xr-x   3 root     wheel         60 Oct  5 09:12 mnt"
      g "drwxrwxrwt   2 root     wheel         40 Oct  5 09:14 tmp"
      ;;
    /home)
      g "total 0"
      g "drwxr-xr-x   3 root     wheel         60 Sep 28 12:00 ."
      g "drwxr-xr-x   5 root     wheel        160 Sep 28 12:00 .."
      g "drwxr-xr-x   2 mrk      staff         64 Oct  5 09:14 mrk"
      ;;
    /home/mrk)
      g "total 0"
      g "drwxr-xr-x   2 mrk      staff         64 Oct  5 09:14 ."
      g "drwxr-xr-x   3 root     wheel         60 Sep 28 12:00 .."
      ;;
    /mnt)
      g "total 0"
      g "drwxr-xr-x   3 root     wheel         60 Oct  5 09:12 ."
      g "drwxr-xr-x   5 root     wheel        160 Sep 28 12:00 .."
      g "drwxr-xr-x   2 root     wheel         64 Oct  5 09:12 floppy"
      ;;
    /mnt/floppy)
      g "total 8"
      g "drwxr-xr-x   2 root     wheel         64 Oct  5 09:12 ."
      g "drwxr-xr-x   3 root     wheel         60 Oct  5 09:12 .."
      g "-rw-r--r--   1 root     wheel        512 Oct  5 09:12 README"
      g "-rwxr-xr-x   1 root     wheel       2048 Oct  5 09:12 setup.sh"
      ;;
    *)
      g "ls: $path: No such file or directory"
      ;;
  esac
}

# ── Boot sequence ────────────────────────────────────────────────────────────
boot_sequence() {
  printf '%s' "$_CLR"
  sleep 0.3

  ll  ">> VAX Bootstrap, Revision 5.2" 0.04
  blank
  ll  "Booting from [RA00]:" 0.2
  blank
  sleep 0.5
  ll  "ra(0,0,0)/vmunix" 0.1
  sleep 0.4
  ll  "62836+8284+90616 start 0x10b4" 0.06
  blank
  sleep 0.5
  ll  "Berkeley Software Distribution  Version 4.3  (soda.csua.berkeley.edu) #1: Mon Jan  9 08:12:03 PST 1989" 0.05
  blank
  ll  "real mem  = 8388608" 0.03
  ll  "avail mem = 7163904" 0.03
  ll  "using 100 buffers containing 819200 bytes of memory" 0.03
  ll  "cpu: VAX 11/780" 0.04
  ll  "ra0 at uba0 csr 0154400 vec 0154, ipl 21" 0.03
  ll  "ra0: RD53, size 138720 sectors" 0.03
  ll  "ry0 at uba0 csr 017720 vec 0260, ipl 14" 0.03
  ll  "ry0: RX50/RX33  (3.5\" HD)  disk present" 0.05
  blank
  sleep 0.3
  lld "/dev/ry0a: Mounting /mnt/floppy ... done." 0.2
  sleep 0.3
  blank
  lld "CSUA  soda.csua.berkeley.edu  (Thu Oct  5 09:13:01 PDT 1989)" 0.15
  sleep 0.5
  blank
  lld "soda login: mrk (auto)" 0.3
  sleep 0.6
  blank
  printf '%s' "$_CLR"
  sleep 0.3
}

# ── Colossal Cave Adventure ──────────────────────────────────────────────────
run_adventure() {
  # Item locations: room name | "inv" | "gone"
  local -A ITEMS=(
    [LAMP]="building"    [CAGE]="building"     [ROD]="debris"
    [KEYS]="building"    [FOOD]="building"      [BOTTLE]="building"
    [GOLD]="nugget_room" [DIAMONDS]="west_fissure" [SILVER]="south_side"
    [JEWELRY]="south_side" [COINS]="west_side"  [CHEST]="gone"
    [VASE]="oriental"    [RUG]="oriental"       [EGGS]="giant_room"
    [TRIDENT]="south_side" [EMERALD]="plover_room" [PYRAMID]="dark_room"
    [PEARL]="reservoir"  [CHAIN]="bear_room"    [AXE]="gone"
  )
  local -a INV=() DEPOSITED=()
  local ROOM="road" MOVES=0 SCORE=0 DEATHS=0
  local LAMP_LIFE=400 LAMP_LIT=1 BATTERY_LOW=0
  local GRATE_LOCKED=1 BRIDGE=0
  local SNAKE_HERE=1 DRAGON_ALIVE=1 TROLL_HERE=1
  local BEAR_CHAINED=1 BEAR_TAME=0 PIRATE_ACTIVE=1 VASE_BROKEN=0
  local BIRD_LOC="bird_chamber"
  local ADV_ON=1

  # ── Helpers ────────────────────────────────────────────────────────────────
  _has()  { local i; for i in "${INV[@]:-}"; do [[ "$i" == "$1" ]] && return 0; done; return 1; }
  _here() { [[ "${ITEMS[$1]:-}" == "$ROOM" ]]; }
  _take() { ITEMS[$1]="inv"; INV+=("$1"); }
  _put()  {
    ITEMS[$1]="${2:-$ROOM}"
    local -a _n=(); local _i
    for _i in "${INV[@]:-}"; do [[ "$_i" != "$1" ]] && _n+=("$_i"); done
    INV=("${_n[@]:-}")
  }
  _treasure() {
    case "$1" in
      GOLD|DIAMONDS|SILVER|JEWELRY|COINS|CHEST|VASE|RUG|EGGS|TRIDENT|EMERALD|PYRAMID|PEARL|CHAIN)
        return 0 ;;
    esac; return 1
  }
  _dark() {
    case "$ROOM" in road|hill|building|valley|forest|slit|outside_grate) return 1;; esac
    [[ "${ITEMS[LAMP]:-}" == "inv" ]] && (( LAMP_LIT )) && return 1
    return 0
  }
  _lamp_check() {
    [[ "${ITEMS[LAMP]:-}" != "inv" ]] && return
    (( LAMP_LIFE-- ))
    if (( LAMP_LIFE == 50 && !BATTERY_LOW )); then
      blank; dg "Your lamp is getting dim.  You'll need more oil soon."; blank; BATTERY_LOW=1
    elif (( LAMP_LIFE <= 0 )); then
      LAMP_LIT=0; blank; dg "Your lamp has run out of oil!"; blank
    fi
  }
  _dwarves() {
    (( MOVES < 30 )) && return
    case "$ROOM" in road|hill|building|valley|forest|slit|outside_grate|below_grate|cobble) return;; esac
    if (( RANDOM % 10 == 0 )); then
      blank
      if _has "AXE"; then
        g "A dwarf attacks!  You throw your axe and it flees."
        _put "AXE" "$ROOM"
      else
        g "A little dwarf with a big knife blocks your path!"
        _adv_die "The dwarf stabs you."
      fi
      blank
    elif (( RANDOM % 16 == 0 )); then
      blank; g "A dwarf threw an axe at you and missed!"; ITEMS[AXE]="$ROOM"; blank
    fi
  }
  _pirate() {
    (( !PIRATE_ACTIVE || MOVES < 40 )) && return
    [[ "$ROOM" == "pirate_lair" ]] && return
    local has_t=0 t
    for t in GOLD DIAMONDS SILVER JEWELRY COINS VASE RUG EGGS TRIDENT EMERALD PYRAMID PEARL CHAIN; do
      _has "$t" && { has_t=1; break; }
    done
    (( !has_t || RANDOM % 18 != 0 )) && return
    blank
    say "Out from the shadows lunges a bearded pirate!  \"Har har!\" he cries, snatching your treasure.  He vanishes into the dark."
    blank
    for t in GOLD DIAMONDS SILVER JEWELRY COINS VASE RUG EGGS TRIDENT EMERALD PYRAMID PEARL CHAIN; do
      _has "$t" && _put "$t" "pirate_lair"
    done
    [[ "${ITEMS[CHEST]:-}" == "gone" ]] && ITEMS[CHEST]="pirate_lair"
    PIRATE_ACTIVE=0
  }
  _adv_die() {
    blank; g "${1:-You are dead.}"; blank; sleep 0.5
    (( DEATHS++ ))
    if (( DEATHS >= 3 )); then
      say "It appears that it is taking you an inordinately long time to get out of the cave.  I'm afraid you're completely dead."
      blank; g "Your score: $SCORE."; blank; ADV_ON=0; return
    fi
    say "There is a loud explosion, and you find yourself sitting next to the road at the start, your clothes in tatters.  Your possessions have been scattered hereabouts."
    blank
    local _it; for _it in "${INV[@]:-}"; do ITEMS[$_it]="road"; done; INV=()
    ROOM="road"; _adv_look
  }

  # ── Room descriptions ───────────────────────────────────────────────────────
  _adv_look() {
    blank
    if _dark; then
      dg "It is pitch dark.  You are likely to be eaten by a grue."; blank; return
    fi
    case "$ROOM" in
      road)
        g "AT END OF ROAD"
        blank
        say "You are standing at the end of a road before a small brick building.  Around you is a forest.  A small stream flows out of the building and down a gully." ;;
      hill)
        g "ON HILL IN ROAD"
        blank
        say "You have walked up a hill, still in the forest.  The road slopes back down the other side.  There is a building in the distance." ;;
      building)
        g "INSIDE BUILDING"
        blank
        say "You are inside a building, a well house for a large spring.  The stream flows out through a pair of 1 foot diameter sewer pipes."
        blank
        dg "(Deposit treasures here to score.)" ;;
      valley)
        g "IN VALLEY"
        blank
        say "You are in a valley in the forest beside a stream tumbling along a rocky bed." ;;
      forest)
        g "IN FOREST"
        blank
        g "You are in open forest, with a deep valley to one side." ;;
      slit)
        g "AT SLIT IN STREAMBED"
        blank
        say "At your feet all the water of the stream splashes into a 2-inch slit in the rock.  Downstream the streambed is bare rock." ;;
      outside_grate)
        g "OUTSIDE GRATE"
        blank
        say "You are in a 20-foot depression floored with bare dirt.  Set into the dirt is a strong steel grate mounted in concrete.  A dry streambed leads into the depression from the north."
        (( GRATE_LOCKED )) && g "The grate is locked." || g "The grate is open." ;;
      below_grate)
        g "BELOW THE GRATE"
        blank
        say "You are in a small chamber beneath a 3x3 steel grate to the surface.  A low crawl over cobbles leads inward to the west." ;;
      cobble)
        g "IN COBBLE CRAWL"
        blank
        say "You are crawling over cobbles in a low passage.  There is a dim light at the east end of the passage." ;;
      debris)
        g "DEBRIS ROOM"
        blank
        say "You are in a debris room filled with stuff washed in from the surface.  A low wide passage with cobbles becomes plugged with mud and debris here, but an awkward canyon leads upward and west.  A note on the wall says:  \"MAGIC WORD XYZZY\"" ;;
      awkward)
        g "AWKWARD SLOPING E/W CANYON"
        blank
        g "You are in an awkward sloping east/west canyon." ;;
      bird_chamber)
        g "BIRD CHAMBER"
        blank
        say "You are in a splendid chamber thirty feet high.  The walls are frozen rivers of orange stone.  An awkward canyon and a good passage exit from east and west sides of the chamber."
        [[ "$BIRD_LOC" == "bird_chamber" ]] && g "A cheerful little bird is sitting here singing." ;;
      small_pit)
        g "AT TOP OF SMALL PIT"
        blank
        say "At your feet is a small pit breathing traces of white mist.  An east passage ends here except for a small crack leading on.  Rough stone steps lead down the pit." ;;
      hall_mists)
        g "IN HALL OF MISTS"
        blank
        say "You are at one end of a vast hall stretching forward out of sight to the west.  There are openings to either side.  Nearby, a wide stone staircase leads downward.  The hall is filled with wisps of white mist swaying to and fro almost as if alive.  A hollow voice reverberates, \"PLUGH\"." ;;
      east_fissure)
        g "ON EAST BANK OF FISSURE"
        blank
        say "You are on the east bank of a fissure slicing clear across the hall.  The mist is quite thick here, and the fissure is too wide to jump."
        (( BRIDGE )) && g "A crystal bridge now spans the fissure." ;;
      west_fissure)
        g "ON WEST BANK OF FISSURE"
        blank
        g "You are on the west side of the fissure in the Hall of Mists."
        (( BRIDGE )) && g "A crystal bridge spans the fissure." ;;
      low_ns)
        g "LOW N/S PASSAGE"
        blank
        say "You are in a low north/south passage at a hole in the floor.  The hole goes down to an east/west passage." ;;
      south_side)
        g "SOUTH SIDE CHAMBER"
        blank
        g "You are in the south side chamber." ;;
      west_side)
        g "WEST SIDE CHAMBER"
        blank
        say "You are in the west side chamber of the Hall of Mists.  An eerie sound can be heard in the distance." ;;
      hall_mt_king)
        g "HALL OF THE MOUNTAIN KING"
        blank
        say "You are in the Hall of the Mountain King, with passages off in all directions."
        (( SNAKE_HERE )) && g "A huge green fierce snake bars the way!" ;;
      low_passage)
        g "LOW PASSAGE"
        blank
        say "You are in a low passage parallel to and north of the Hall of the Mountain King." ;;
      y2)
        g "AT \"Y2\""
        blank
        say "You are in a large room, with a passage to the south, a passage to the west, and a wall of broken rock to the east.  There is a large \"Y2\" on a rock in the room's center." ;;
      jumble)
        g "JUMBLE OF ROCK"
        blank
        g "You are in a jumble of rock, with cracks everywhere." ;;
      dirty)
        g "DIRTY PASSAGE"
        blank
        say "You are in a dirty broken passage.  To the east is a crawl.  To the west is a large passage.  Above you is a hole to a passage." ;;
      dusty)
        g "DUSTY ROCK ROOM"
        blank
        say "You are in a large room full of dusty rocks.  There is a big hole in the floor.  There are cracks everywhere, and a passage leading east." ;;
      complex)
        g "COMPLEX JUNCTION"
        blank
        say "You are at a complex junction.  A low hands-and-knees passage from the north joins a higher crawl from the east to make a walking passage going west.  There is also a large room above (climb up) and a hole going down." ;;
      bedquilt)
        g "IN BEDQUILT"
        blank
        g "You are in bedquilt, a long east/west passage with holes everywhere." ;;
      twopit)
        g "IN TWOPIT ROOM"
        blank
        say "You are in a large low circular chamber whose floor is an interlocking arrangement of huge honeycombed rocks.  Empty pits are everywhere." ;;
      plover_room)
        g "IN PLOVER ROOM"
        blank
        say "You are in a small chamber lit by an eerie green light.  An extremely narrow tunnel exits to the west.  A dark corridor leads northeast." ;;
      dark_room)
        g "IN DARK ROOM"
        blank
        g "You are in the Dark Room.  A corridor leads southwest." ;;
      alcove)
        g "IN ALCOVE"
        blank
        say "You are in an alcove.  A small northwest passage seems to widen after a short distance.  An extremely tight tunnel leads east." ;;
      oriental)
        g "IN ORIENTAL ROOM"
        blank
        say "This is the oriental room.  Ancient oriental cave drawings cover the walls.  A gently sloping passage leads upward to the north, another goes east, and a rough inhospitable one to the south." ;;
      misty)
        g "IN MISTY CAVERN"
        blank
        say "You are following a wide path around the outer edge of a large cavern.  Far below, through a heavy white mist, strange lights can be seen.  Footing is difficult here." ;;
      slab)
        g "IN SLAB ROOM"
        blank
        g "You are in a large low room.  Rough slabs of rock support the ceiling." ;;
      giant_room)
        g "GIANT ROOM"
        blank
        say "You are in the Giant Room.  The ceiling here is too high up for your lamp to illuminate it.  Cavernous passages lead east, north, and south.  On the wall is scrawled:  \"FEE FIE FOE FOO\"" ;;
      nugget_room)
        g "LARGE LOW ROOM"
        blank
        say "You are in a large low room.  The walls are mostly crumbling rock except for a rough stone passage to the east." ;;
      bear_room)
        g "SECRET N/E CANYON"
        blank
        g "You are in a secret canyon which exits to the north and east."
        (( BEAR_CHAINED )) && g "A menacing bear is chained to the wall here."
        (( BEAR_TAME && !BEAR_CHAINED )) && g "There is a contented bear here." ;;
      secret_canyon)
        g "SECRET CANYON"
        blank
        if (( DRAGON_ALIVE )); then
          say "You are in a secret canyon.  A huge green fierce dragon bars the passage from east to west.  Its eyes gleam with fierce hunger."
        else
          say "You are in a secret canyon.  The body of a huge dead dragon is lying off to one side of the passage."
        fi ;;
      troll_bridge)
        g "BRIDGE OVER CHASM"
        blank
        say "A rickety wooden bridge extends across the chasm, vanishing into the mist.  A sign posted by the chasm reads:  \"STOP! PAY TROLL!\""
        (( TROLL_HERE )) && g "A burly troll stands by the bridge demanding a treasure." ;;
      reservoir)
        g "AT RESERVOIR"
        blank
        say "You are at the edge of a large underground reservoir.  An opaque cloud of white mist fills the room and rises rapidly." ;;
      maze1|maze2|maze3|maze4|maze5)
        g "MAZE OF TWISTY LITTLE PASSAGES"
        blank
        g "You are in a maze of twisty little passages, all alike." ;;
      dead_end)
        g "DEAD END"
        blank
        g "Dead end." ;;
      pirate_lair)
        g "PIRATE'S LAIR"
        blank
        g "Dead end.  You have found the pirate's secret hideout!" ;;
    esac
    blank
    # List items in room
    local _it
    for _it in LAMP CAGE ROD KEYS FOOD BOTTLE GOLD DIAMONDS SILVER JEWELRY \
               COINS CHEST VASE RUG EGGS TRIDENT EMERALD PYRAMID PEARL CHAIN AXE; do
      [[ "${ITEMS[$_it]:-}" != "$ROOM" ]] && continue
      case "$_it" in
        LAMP)     g "There is a shiny brass lamp here." ;;
        CAGE)     [[ "$BIRD_LOC" == "inv" ]] && g "There is a small cage (with bird) here." \
                                              || g "There is a small wicker cage here." ;;
        ROD)      g "There is a black rod with a rusty star on the end here." ;;
        KEYS)     g "There is a set of keys here." ;;
        FOOD)     g "There is food here." ;;
        BOTTLE)   g "There is an empty bottle here." ;;
        GOLD)     g "There is a large sparkling nugget of gold here!" ;;
        DIAMONDS) g "There are diamonds here!" ;;
        SILVER)   g "There are bars of silver here!" ;;
        JEWELRY)  g "There is precious jewelry here!" ;;
        COINS)    g "There are many coins here!" ;;
        CHEST)    g "There is a treasure chest here!" ;;
        VASE)     (( VASE_BROKEN )) && g "There are some worthless shards of pottery here." \
                                    || g "There is a Ming vase here!" ;;
        RUG)      g "There is a Persian rug spread out on the floor here!" ;;
        EGGS)     g "There is a large nest here, full of golden eggs!" ;;
        TRIDENT)  g "There is a jewel-encrusted trident here!" ;;
        EMERALD)  g "There is an emerald the size of a plover's egg here!" ;;
        PYRAMID)  g "There is a platinum pyramid here, 8 inches on a side!" ;;
        PEARL)    g "There is a glistening pearl here!" ;;
        CHAIN)    g "There is a golden chain lying here!" ;;
        AXE)      g "There is a dwarf's axe lying here." ;;
      esac
    done
    [[ "$BIRD_LOC" == "$ROOM" ]] && g "There is a little bird here, singing."
    blank
  }

  # ── Movement ────────────────────────────────────────────────────────────────
  _adv_go() {
    local dir="$1" dest="" ok=1
    case "$ROOM:$dir" in
      road:w|road:u|road:hill)                   dest="hill" ;;
      road:e|road:in|road:building)              dest="building" ;;
      road:s|road:d|road:valley)                 dest="valley" ;;
      road:n|road:forest)                        dest="forest" ;;
      hill:e|hill:d|hill:road)                   dest="road" ;;
      hill:w|hill:forest)                        dest="forest" ;;
      building:w|building:out)                   dest="road" ;;
      valley:n|valley:u|valley:road)             dest="road" ;;
      valley:s|valley:d)                         dest="slit" ;;
      valley:w|valley:forest)                    dest="forest" ;;
      forest:e|forest:valley)                    dest="valley" ;;
      forest:w|forest:road)                      dest="road" ;;
      forest:n|forest:s)                         dest="forest" ;;
      slit:n|slit:u|slit:valley)                 dest="valley" ;;
      slit:s|slit:d)                             dest="outside_grate" ;;
      outside_grate:n|outside_grate:slit)        dest="slit" ;;
      outside_grate:d|outside_grate:in)
        (( !GRATE_LOCKED )) && dest="below_grate" || { blank; g "The grate is locked."; blank; ok=0; } ;;
      below_grate:u|below_grate:out)
        (( !GRATE_LOCKED )) && dest="outside_grate" || { blank; g "The grate is locked from below."; blank; ok=0; } ;;
      below_grate:w)                             dest="cobble" ;;
      cobble:e)                                  dest="below_grate" ;;
      cobble:w)                                  dest="debris" ;;
      debris:e)                                  dest="cobble" ;;
      debris:w|debris:u|debris:canyon)           dest="awkward" ;;
      awkward:e|awkward:d)                       dest="debris" ;;
      awkward:w)                                 dest="bird_chamber" ;;
      bird_chamber:e)                            dest="awkward" ;;
      bird_chamber:w|bird_chamber:pit)           dest="small_pit" ;;
      small_pit:e)                               dest="bird_chamber" ;;
      small_pit:d)                               dest="hall_mists" ;;
      hall_mists:u|hall_mists:stairs)            dest="small_pit" ;;
      hall_mists:n|hall_mists:low)               dest="low_ns" ;;
      hall_mists:s|hall_mists:hall)              dest="hall_mt_king" ;;
      hall_mists:w|hall_mists:fissure)           dest="east_fissure" ;;
      east_fissure:e|east_fissure:hall)          dest="hall_mists" ;;
      east_fissure:w|east_fissure:jump|east_fissure:cross)
        (( BRIDGE )) && dest="west_fissure" || { blank; g "The fissure is too wide to jump."; blank; ok=0; } ;;
      west_fissure:e)
        (( BRIDGE )) && dest="east_fissure" || { blank; g "There is no way across."; blank; ok=0; } ;;
      west_fissure:w)                            dest="west_side" ;;
      low_ns:s|low_ns:hall)                      dest="hall_mists" ;;
      low_ns:n)                                  dest="low_passage" ;;
      low_ns:w|low_ns:d)                         dest="south_side" ;;
      south_side:e|south_side:u)                 dest="low_ns" ;;
      west_side:e)                               dest="west_fissure" ;;
      hall_mt_king:n)                            dest="low_passage" ;;
      hall_mt_king:s|hall_mt_king:w|hall_mt_king:e)
        if (( SNAKE_HERE )); then blank; g "You can't get past the snake!"; blank; ok=0
        else case "$dir" in s) dest="misty";; w) dest="west_side";; e) dest="low_ns";; esac; fi ;;
      low_passage:s|low_passage:hall)            dest="hall_mt_king" ;;
      low_passage:n)                             dest="y2" ;;
      y2:s|y2:hall)                              dest="low_passage" ;;
      y2:w)                                      dest="jumble" ;;
      y2:n)                                      dest="dirty" ;;
      jumble:e|jumble:y2)                        dest="y2" ;;
      jumble:u)                                  dest="hall_mists" ;;
      dirty:s|dirty:y2)                          dest="y2" ;;
      dirty:e)                                   dest="dusty" ;;
      dirty:w)                                   dest="complex" ;;
      dirty:n|dirty:u)                           dest="maze1" ;;
      dusty:w)                                   dest="dirty" ;;
      dusty:e)                                   dest="bedquilt" ;;
      complex:e)                                 dest="dusty" ;;
      complex:n)                                 dest="bedquilt" ;;
      complex:u)                                 dest="giant_room" ;;
      complex:d)                                 dest="low_passage" ;;
      bedquilt:w)                                dest="complex" ;;
      bedquilt:n)                                dest="twopit" ;;
      bedquilt:e)                                dest="slab" ;;
      slab:w)                                    dest="bedquilt" ;;
      slab:u)                                    dest="giant_room" ;;
      slab:s|slab:oriental)                      dest="oriental" ;;
      twopit:s|twopit:bedquilt)                  dest="bedquilt" ;;
      twopit:w)                                  dest="plover_room" ;;
      giant_room:w|giant_room:d)                 dest="complex" ;;
      giant_room:e)                              dest="nugget_room" ;;
      giant_room:n)                              dest="misty" ;;
      giant_room:s)                              dest="slab" ;;
      nugget_room:w|nugget_room:giant)           dest="giant_room" ;;
      plover_room:e|plover_room:twopit)          dest="twopit" ;;
      plover_room:ne)                            dest="dark_room" ;;
      plover_room:w|plover_room:alcove)          dest="alcove" ;;
      dark_room:sw|dark_room:plover)             dest="plover_room" ;;
      alcove:e)                                  dest="plover_room" ;;
      alcove:nw)                                 dest="oriental" ;;
      oriental:s|oriental:d)                     dest="slab" ;;
      oriental:n|oriental:u)                     dest="misty" ;;
      oriental:e)                                dest="alcove" ;;
      misty:n|misty:oriental)                    dest="oriental" ;;
      misty:s|misty:giant)                       dest="giant_room" ;;
      misty:e|misty:hall)                        dest="hall_mt_king" ;;
      misty:w|misty:chasm)                       dest="troll_bridge" ;;
      troll_bridge:e|troll_bridge:misty)         dest="misty" ;;
      troll_bridge:w|troll_bridge:cross)
        (( !TROLL_HERE )) && dest="bear_room" || { blank; g "The troll refuses to let you pass."; blank; ok=0; } ;;
      bear_room:e|bear_room:troll)               dest="troll_bridge" ;;
      bear_room:n)
        (( BEAR_CHAINED && !BEAR_TAME )) && { blank; g "The bear won't let you by."; blank; ok=0; } || dest="secret_canyon" ;;
      secret_canyon:s|secret_canyon:bear)        dest="bear_room" ;;
      secret_canyon:n|secret_canyon:e)
        (( DRAGON_ALIVE )) && { blank; g "The dragon blocks the way!"; blank; ok=0; } || dest="reservoir" ;;
      reservoir:s|reservoir:canyon)              dest="secret_canyon" ;;
      maze1:n)  dest="maze2" ;; maze1:e)         dest="maze3" ;;
      maze1:s|maze1:w|maze1:u|maze1:d)           dest="dead_end" ;;
      maze2:s)  dest="maze1" ;; maze2:n|maze2:e) dest="maze3" ;;
      maze2:w|maze2:u|maze2:d)                   dest="dead_end" ;;
      maze3:w)  dest="maze1" ;; maze3:s)         dest="maze2" ;; maze3:n) dest="maze4" ;;
      maze3:e|maze3:u|maze3:d)                   dest="dead_end" ;;
      maze4:s)  dest="maze3" ;; maze4:n)         dest="maze5" ;;
      maze4:e|maze4:w|maze4:u|maze4:d)           dest="dead_end" ;;
      maze5:s)  dest="maze4" ;; maze5:w)         dest="pirate_lair" ;;
      maze5:n|maze5:e|maze5:u|maze5:d)           dest="dead_end" ;;
      dead_end:*)                                dest="maze1" ;;
      pirate_lair:e)                             dest="maze5" ;;
      pirate_lair:*)                             dest="dead_end" ;;
      *)  blank; g "I can't go that way."; blank; ok=0 ;;
    esac
    if (( ok )) && [[ -n "$dest" ]]; then
      ROOM="$dest"; (( MOVES++ ))
      if _dark && (( RANDOM % 6 == 0 )); then
        _adv_die "You stumbled in the dark and fell into a pit."; return
      fi
      _lamp_check; _dwarves; _pirate; _adv_look
    fi
  }

  # ── Intro ────────────────────────────────────────────────────────────────────
  printf '%s' "$_CLR"; draw_screen; tput cup "$SCREEN_HEIGHT" 0
  blank
  g "ADVENTURE"
  dg "Colossal Cave  --  Crowther & Woods, 1976  --  4.3BSD port"
  blank
  say "Somewhere nearby is Colossal Cave, where others have found fortunes in treasure and gold, though it is rumored that some who enter are never seen again.  Magic is said to work in the cave.  I will be your eyes and hands.  Direct me with commands of 1 or 2 words."
  blank
  dg "Type HELP for commands."
  blank
  _adv_look

  # ── Game loop ────────────────────────────────────────────────────────────────
  while (( ADV_ON )); do
    printf '%s' "${_BG}> ${_R}${_G}"
    local raw; IFS= read -r raw || { printf '%s\n' "$_R"; break; }
    printf '%s' "$_R"

    local cmd="${raw,,}"
    cmd="${cmd#"${cmd%%[![:space:]]*}"}"; cmd="${cmd%"${cmd##*[![:space:]]}"}"
    local verb="${cmd%% *}" noun="${cmd#* }"
    [[ "$noun" == "$verb" ]] && noun=""
    noun="${noun#the }"; noun="${noun#a }"; noun="${noun#an }"

    # Direction shortcuts
    local _dir=""
    case "$verb" in
      n|north) _dir="n" ;; s|south) _dir="s" ;; e|east)  _dir="e" ;; w|west) _dir="w" ;;
      u|up)    _dir="u" ;; d|down)  _dir="d" ;; ne)      _dir="ne" ;; nw)    _dir="nw" ;;
      se)      _dir="se";; sw)      _dir="sw";; in|enter) _dir="in" ;;
    esac
    if [[ -n "$_dir" ]]; then _adv_go "$_dir"; continue; fi
    if [[ "$verb" == "go" ]]; then
      local _d2=""
      case "$noun" in
        n|north) _d2="n";; s|south) _d2="s";; e|east) _d2="e";; w|west) _d2="w";;
        u|up) _d2="u";; d|down) _d2="d";; ne) _d2="ne";; nw) _d2="nw";;
        se) _d2="se";; sw) _d2="sw";; in|enter|inside|cave|grate) _d2="in";;
        building|house) _d2="building";; valley) _d2="valley";; hill) _d2="hill";;
        *) blank; g "Go where?"; blank ;;
      esac
      [[ -n "$_d2" ]] && _adv_go "$_d2"; continue
    fi

    case "$verb" in

      look|l)  _adv_look ;;

      take|get|pick|grab)
        [[ "$verb" == "pick" && "${noun:0:3}" == "up " ]] && noun="${noun#up }"
        local _ti=""
        case "$noun" in
          lamp|lantern|"brass lamp")           _ti="LAMP"     ;;
          cage|"wicker cage"|"small cage")     _ti="CAGE"     ;;
          rod|"black rod"|"rusty rod")         _ti="ROD"      ;;
          keys|key|"set of keys")              _ti="KEYS"     ;;
          food|rations|"tasty food")           _ti="FOOD"     ;;
          bottle|"empty bottle")               _ti="BOTTLE"   ;;
          gold|nugget|"gold nugget")           _ti="GOLD"     ;;
          diamonds|diamond)                    _ti="DIAMONDS" ;;
          silver|bars|"silver bars")           _ti="SILVER"   ;;
          jewelry|jewels|"precious jewelry")   _ti="JEWELRY"  ;;
          coins|"old coins")                   _ti="COINS"    ;;
          chest|"treasure chest")              _ti="CHEST"    ;;
          vase|"ming vase")                    _ti="VASE"     ;;
          rug|"persian rug")                   _ti="RUG"      ;;
          eggs|egg|"golden eggs")              _ti="EGGS"     ;;
          trident|"jeweled trident")           _ti="TRIDENT"  ;;
          emerald)                             _ti="EMERALD"  ;;
          pyramid|"platinum pyramid")          _ti="PYRAMID"  ;;
          pearl|"glistening pearl")            _ti="PEARL"    ;;
          chain|"golden chain")                _ti="CHAIN"    ;;
          axe|"dwarf's axe"|"dwarfs axe")     _ti="AXE"      ;;
          bird)
            if [[ "$BIRD_LOC" == "$ROOM" ]]; then
              if _has "CAGE"; then
                if _has "ROD"; then blank; g "The bird is frightened by the rod and won't let you near."; blank
                else blank; g "You catch the bird in the cage."; blank; BIRD_LOC="inv"; fi
              else blank; g "You have nothing to carry the bird in."; blank; fi
            elif [[ "$BIRD_LOC" == "inv" ]]; then blank; g "The bird is already caged."; blank
            else blank; g "You see no bird here."; blank; fi
            continue ;;
          *) blank; g "I don't see that here."; blank; continue ;;
        esac
        blank
        if [[ "${ITEMS[$_ti]:-}" == "$ROOM" ]]; then
          [[ "$_ti" == "CHAIN" ]] && (( BEAR_CHAINED )) && { g "The chain is secured to the bear."; blank; continue; }
          _take "$_ti"; g "OK."; _treasure "$_ti" && (( SCORE += 2 ))
        elif _has "$_ti"; then g "You're already carrying it!"
        else g "I don't see that here."; fi
        blank ;;

      drop|leave|put|throw)
        local _di=""
        case "$noun" in
          lamp|lantern)           _di="LAMP"    ;; cage)               _di="CAGE"    ;;
          rod|"black rod")        _di="ROD"     ;; keys|key)           _di="KEYS"    ;;
          food)                   _di="FOOD"    ;; bottle)             _di="BOTTLE"  ;;
          gold|nugget)            _di="GOLD"    ;; diamonds|diamond)   _di="DIAMONDS";;
          silver|bars)            _di="SILVER"  ;; jewelry|jewels)     _di="JEWELRY" ;;
          coins)                  _di="COINS"   ;; chest)              _di="CHEST"   ;;
          vase)                   _di="VASE"    ;; rug)                _di="RUG"     ;;
          eggs|egg)               _di="EGGS"    ;; trident)            _di="TRIDENT" ;;
          emerald)                _di="EMERALD" ;; pyramid)            _di="PYRAMID" ;;
          pearl)                  _di="PEARL"   ;; chain|"golden chain") _di="CHAIN" ;;
          axe)                    _di="AXE"     ;;
          bird)
            if [[ "$BIRD_LOC" == "inv" ]]; then
              blank
              if [[ "$ROOM" == "hall_mt_king" ]] && (( SNAKE_HERE )); then
                g "The bird attacks the snake's eyes!  The snake flees into the dark."
                BIRD_LOC="gone"; SNAKE_HERE=0; (( SCORE += 15 ))
              elif [[ "$ROOM" == "troll_bridge" ]] && (( TROLL_HERE )); then
                g "The troll swats your bird away.  It is dead."; BIRD_LOC="gone"
              else
                g "You release the bird.  It flies away."; BIRD_LOC="$ROOM"
              fi
              blank
            else blank; g "You aren't carrying the bird."; blank; fi
            continue ;;
          *) blank; g "You aren't carrying that."; blank; continue ;;
        esac
        blank
        if [[ -n "$_di" ]] && _has "$_di"; then
          # Throw treasure at troll
          if [[ "$verb" == "throw" && "$ROOM" == "troll_bridge" ]] && (( TROLL_HERE )) && _treasure "$_di"; then
            g "The troll snatches your treasure and sinks out of sight."
            _put "$_di" "gone"; TROLL_HERE=0; blank; continue
          fi
          # Drop vase without rug
          if [[ "$_di" == "VASE" ]] && ! _has "RUG"; then
            g "The vase drops with a delicate crash."; VASE_BROKEN=1; _put "$_di"; blank; continue
          fi
          _put "$_di"; g "OK."
          # Deposit treasure in building
          if [[ "$ROOM" == "building" ]] && _treasure "$_di" && ! (( VASE_BROKEN && "$_di" == "VASE" )); then
            local _already=0 _dep
            for _dep in "${DEPOSITED[@]:-}"; do [[ "$_dep" == "$_di" ]] && { _already=1; break; }; done
            if (( !_already )); then
              DEPOSITED+=("$_di"); (( SCORE += 15 )); blank; g "Thank you."
              if (( ${#DEPOSITED[@]} >= 14 )); then
                blank
                g "You have recovered all the treasure from the cave."
                blank
                g "Your total score is $SCORE points."
                blank
                dg "(Type QUIT to return to the shell.)"
              fi
            fi
          fi
        else g "You aren't carrying that."; fi
        blank ;;

      inventory|i|inv)
        blank
        if (( ${#INV[@]} == 0 )) && [[ "$BIRD_LOC" != "inv" ]]; then
          g "You are carrying nothing."
        else
          g "You are carrying:"
          local _it; for _it in "${INV[@]:-}"; do
            case "$_it" in
              LAMP)     g "  a shiny brass lamp"     ;; CAGE)     [[ "$BIRD_LOC" == "inv" ]] && g "  a wicker cage (with bird)" || g "  a wicker cage" ;;
              ROD)      g "  a black rod with a rusty star" ;; KEYS)     g "  a set of keys"         ;;
              FOOD)     g "  food"                   ;; BOTTLE)   g "  an empty bottle"         ;;
              GOLD)     g "  a gold nugget"           ;; DIAMONDS) g "  diamonds"                ;;
              SILVER)   g "  silver bars"             ;; JEWELRY)  g "  precious jewelry"        ;;
              COINS)    g "  coins"                   ;; CHEST)    g "  a treasure chest"        ;;
              VASE)     g "  a Ming vase"             ;; RUG)      g "  a Persian rug"           ;;
              EGGS)     g "  golden eggs"             ;; TRIDENT)  g "  a jeweled trident"       ;;
              EMERALD)  g "  an emerald"              ;; PYRAMID)  g "  a platinum pyramid"      ;;
              PEARL)    g "  a glistening pearl"      ;; CHAIN)    g "  a golden chain"          ;;
              AXE)      g "  a dwarf's axe"           ;;
            esac
          done
        fi
        blank ;;

      examine|x|inspect)
        blank
        case "$noun" in
          lamp|lantern)
            { _has "LAMP" || _here "LAMP"; } && g "A shiny brass lamp.  It is burning." || g "You don't see that." ;;
          rod|"black rod")
            { _has "ROD" || _here "ROD"; } && g "A jet-black rod with a rusty yellow star on the end." || g "You don't see that." ;;
          cage)
            { _has "CAGE" || _here "CAGE"; } && { [[ "$BIRD_LOC" == "inv" ]] && g "A small cage with a cheerful bird inside." || g "A small wicker cage."; } || g "You don't see that." ;;
          bird)
            if [[ "$BIRD_LOC" == "inv" ]]; then g "A cheerful little bird, now captive."
            elif [[ "$BIRD_LOC" == "$ROOM" ]]; then g "A cheerful little bird, sitting and singing."
            else g "There is no bird here."; fi ;;
          snake)
            [[ "$ROOM" == "hall_mt_king" ]] && (( SNAKE_HERE )) && g "A huge green fierce snake.  Very unhappy." || g "You don't see a snake." ;;
          dragon)
            [[ "$ROOM" == "secret_canyon" ]] && { (( DRAGON_ALIVE )) && g "An enormous dragon.  Very much alive." || g "A large dead dragon."; } || g "You don't see a dragon." ;;
          troll)
            [[ "$ROOM" == "troll_bridge" ]] && (( TROLL_HERE )) && g "A squat ugly troll demanding a treasure to pass." || g "You don't see a troll." ;;
          bear)
            [[ "$ROOM" == "bear_room" ]] && { (( BEAR_CHAINED )) && g "A large brown bear, chained to the wall." || g "A bear, no longer chained.  It seems friendly."; } || g "You don't see a bear." ;;
          grate)
            { [[ "$ROOM" == "outside_grate" ]] || [[ "$ROOM" == "below_grate" ]]; } && { (( GRATE_LOCKED )) && g "A heavy steel grate, firmly locked." || g "A steel grate, currently open."; } || g "You don't see a grate." ;;
          fissure)
            { [[ "$ROOM" == "east_fissure" ]] || [[ "$ROOM" == "west_fissure" ]]; } && { (( BRIDGE )) && g "A crystal bridge spans the fissure." || g "A deep fissure.  Far too wide to jump."; } || g "You don't see a fissure." ;;
          *) g "Nothing special about it." ;;
        esac
        blank ;;

      open|unlock)
        blank
        if { [[ "$ROOM" == "outside_grate" ]] || [[ "$ROOM" == "below_grate" ]]; }; then
          _has "KEYS" && { GRATE_LOCKED=0; g "The grate is now unlocked."; } || g "You have nothing to unlock it with."
        else g "I don't know how to open that here."; fi
        blank ;;

      lock|close)
        blank
        if { [[ "$ROOM" == "outside_grate" ]] || [[ "$ROOM" == "below_grate" ]]; } && _has "KEYS"; then
          GRATE_LOCKED=1; g "The grate is now locked."
        else g "I don't know how to do that."; fi
        blank ;;

      wave|swing)
        blank
        if { [[ "$noun" == "rod" ]] || [[ "$noun" == "black rod" ]]; } && _has "ROD"; then
          if [[ "$ROOM" == "east_fissure" ]] || [[ "$ROOM" == "west_fissure" ]]; then
            (( !BRIDGE )) && { BRIDGE=1; g "A crystal bridge now spans the fissure!"; (( SCORE += 10 )); } \
                          || { BRIDGE=0; g "The crystal bridge vanishes!"; }
          else g "Nothing happens."; fi
        else g "Nothing happens."; fi
        blank ;;

      light|"turn on")
        blank; _has "LAMP" && { LAMP_LIT=1; g "Your lamp is now on."; } || g "You have nothing to light."; blank ;;

      extinguish|"turn off"|douse|off)
        blank; _has "LAMP" && { LAMP_LIT=0; g "Your lamp is now off."; } || g "You have nothing to extinguish."; blank ;;

      feed)
        blank
        if [[ "$noun" == "bear" ]] && [[ "$ROOM" == "bear_room" ]]; then
          _has "FOOD" && {
            g "The bear takes the food and seems tamer now."; BEAR_TAME=1
            ITEMS[FOOD]="gone"
            local -a _fb=(); local _di; for _di in "${INV[@]:-}"; do [[ "$_di" != "FOOD" ]] && _fb+=("$_di"); done; INV=("${_fb[@]:-}")
          } || g "You have nothing to feed the bear."
        elif [[ "$noun" == "troll" ]]; then g "Trolls aren't interested in food."
        else g "There's nothing here to feed."; fi
        blank ;;

      free|unchain)
        blank
        [[ "$ROOM" == "bear_room" ]] && (( BEAR_TAME && BEAR_CHAINED )) && {
          _has "KEYS" && { g "You free the bear.  It wanders off happily."; BEAR_CHAINED=0; ITEMS[CHAIN]="bear_room"; } \
                      || g "You need the keys to undo the lock."
        } || g "Nothing to free here."
        blank ;;

      drink)
        blank
        case "$ROOM" in
          building|valley|reservoir|slit) g "You drink from the stream.  Refreshing." ;;
          *) g "There is nothing to drink here." ;;
        esac
        blank ;;

      eat)
        blank
        _has "FOOD" && {
          g "Thank you, it was delicious!"
          ITEMS[FOOD]="gone"
          local -a _ef=(); local _di; for _di in "${INV[@]:-}"; do [[ "$_di" != "FOOD" ]] && _ef+=("$_di"); done; INV=("${_ef[@]:-}")
        } || g "You have nothing to eat."
        blank ;;

      kill|attack|hit|fight)
        blank
        case "$noun" in
          snake)
            [[ "$ROOM" == "hall_mt_king" ]] && (( SNAKE_HERE )) && _adv_die "Attacking the snake proves fatal." || g "There's no snake here." ;;
          dragon)
            [[ "$ROOM" == "secret_canyon" ]] && (( DRAGON_ALIVE )) && g "With what, your bare hands?  (Say YES to try.)" || g "There's no dragon here." ;;
          troll)
            [[ "$ROOM" == "troll_bridge" ]] && (( TROLL_HERE )) && g "Trolls are hard to kill.  Throw it a treasure instead." || g "There's no troll here." ;;
          dwarf)
            _has "AXE" && {
              g "You throw the axe.  It misses.  The dwarf scurries away."
              _put "AXE" "$ROOM"
            } || g "You have nothing to throw at it." ;;
          *) g "There's nothing here to attack." ;;
        esac
        blank ;;

      yes)
        blank
        if [[ "$ROOM" == "secret_canyon" ]] && (( DRAGON_ALIVE )); then
          g "Congratulations!  You have just vanquished a dragon with your"
          g "bare hands!  (Unbelievable, isn't it?)"
          DRAGON_ALIVE=0; (( SCORE += 25 ))
        else g "OK."; fi
        blank ;;

      no) blank; g "OK."; blank ;;

      score)
        blank; g "Your score so far: $SCORE.  Moves: $MOVES.  Treasures deposited: ${#DEPOSITED[@]}/14."; blank ;;

      help|"?")
        blank
        g "Commands:"
        g "  Movement:  N S E W U D NE NW SE SW  IN  OUT"
        g "  Items:     TAKE <item>   DROP <item>   THROW <item>"
        g "  Actions:   OPEN/UNLOCK   WAVE <rod>    LIGHT/EXTINGUISH LAMP"
        g "             FEED <beast>  FREE <beast>  ATTACK <creature>"
        g "             DRINK  EAT    YES"
        g "  Info:      LOOK (L)      INVENTORY (I)   SCORE"
        g "             EXAMINE <thing>  (X <thing>)"
        g "  Magic:     XYZZY  PLUGH  PLOVER"
        g "  Session:   QUIT"
        blank ;;

      xyzzy)
        blank
        if [[ "$ROOM" == "debris" || "$ROOM" == "building" ]]; then
          g ">>Swoosh!<<"
          blank; [[ "$ROOM" == "debris" ]] && ROOM="building" || ROOM="debris"; _adv_look
        else dg "Nothing happens."; blank; fi ;;

      plugh)
        blank
        if [[ "$ROOM" == "y2" || "$ROOM" == "building" ]]; then
          g ">>Swoosh!<<"
          blank; [[ "$ROOM" == "y2" ]] && ROOM="building" || ROOM="y2"; _adv_look
        else dg "A hollow voice says \"PLUGH\"."; blank; fi ;;

      plover)
        blank
        if [[ "$ROOM" == "plover_room" ]]; then
          g ">>Swoosh!<<"; blank; ROOM="outside_grate"; _adv_look
        elif [[ "$ROOM" == "twopit" || "$ROOM" == "outside_grate" ]]; then
          g ">>Swoosh!<<"; blank; ROOM="plover_room"; _adv_look
        else dg "A hollow voice says \"PLOVER\"."; blank; fi ;;

      fee|fie|foe|foo)
        blank; dg "Nothing happens."; blank ;;

      quit|q|bye)
        blank; g "Your final score is $SCORE, in $MOVES moves."; blank; ADV_ON=0 ;;

      save|restore) blank; g "Save/restore not implemented in this port."; blank ;;
      "")   ;;
      *)    blank; g "I don't understand that."; blank ;;

    esac
  done
  printf '%s' "$_CLR"; draw_screen; tput cup "$SCREEN_HEIGHT" 0; blank
}

# ── Shell prompt ─────────────────────────────────────────────────────────────
prompt_str() {
  local p="$CWD"
  [[ "$p" == "/home/mrk" ]] && p="~"
  printf '%s' "mrk@soda:${p}% "
}

# ── Unix shell ───────────────────────────────────────────────────────────────
unix_shell() {
  sleep 0.2
  g "Last login: Wed Oct  4 18:03:41 1989 on console"
  blank

  while true; do
    printf '%s' "${_BG}$(prompt_str)${_R}${_G}"
    IFS= read -r raw_input || { printf '%s\n' "$_R"; tui_cleanup; exit 1; }
    printf '%s' "$_R"

    local input verb remainder
    input="${raw_input#"${raw_input%%[![:space:]]*}"}"
    input="${input%"${input##*[![:space:]]}"}"
    verb="${input%% *}"
    remainder="${input#* }"
    [[ "$remainder" == "$verb" ]] && remainder=""

    case "$verb" in

      # ── Navigation ──────────────────────────────────────────────────────────
      ls)
        blank
        local ls_path="$CWD"
        if [[ -n "$remainder" ]]; then
          local ls_arg="${remainder##-[^ ]* }"
          [[ "$ls_arg" == -* ]] && ls_arg=""
          [[ -n "$ls_arg" ]] && ls_path=$(resolve_path "$ls_arg")
        fi
        list_dir "$ls_path"
        blank
        ;;

      cd)
        if [[ -z "$remainder" ]]; then
          CWD="/home/mrk"
          draw_screen
        else
          local new_cwd
          new_cwd=$(resolve_path "$remainder")
          case "$new_cwd" in
            /|/home|/home/mrk|/mnt|/mnt/floppy|/tmp)
              CWD="$new_cwd"; draw_screen ;;
            *)
              blank; g "soda: $remainder: No such file or directory"; blank ;;
          esac
        fi
        ;;

      pwd)
        blank; g "$CWD"; blank
        ;;

      # ── File operations ──────────────────────────────────────────────────────
      cat)
        blank
        local cat_path
        cat_path=$(resolve_path "${remainder:-}")
        case "$cat_path" in
          /mnt/floppy/README)
            g "MRK Setup Disk  v1.0"
            g "CSUA -- Computer Science Undergraduate Association"
            g "University of California, Berkeley"
            blank
            g "Run ./setup.sh to configure your workstation."
            ;;
          /mnt/floppy/setup.sh)
            g "#!/bin/sh"
            g "# mrk workstation setup"
            g "exec /usr/local/bin/mrk-install"
            ;;
          "$(resolve_path '')")
            g "cat: missing operand" ;;
          *)
            g "cat: $remainder: No such file or directory" ;;
        esac
        blank
        ;;

      more|less)
        blank
        if [[ -z "$remainder" ]]; then
          g "Usage: $verb <filename>"
        else
          local page_path
          page_path=$(resolve_path "$remainder")
          case "$page_path" in
            /mnt/floppy/README)
              g "MRK Setup Disk  v1.0"
              g "CSUA -- Computer Science Undergraduate Association"
              g "University of California, Berkeley"
              blank
              g "Run ./setup.sh to configure your workstation."
              blank
              dg "(END)"
              ;;
            /mnt/floppy/setup.sh)
              g "#!/bin/sh"
              g "exec /usr/local/bin/mrk-install"
              blank
              dg "(END)"
              ;;
            *)
              g "$verb: $remainder: No such file or directory" ;;
          esac
        fi
        blank
        ;;

      file)
        blank
        if [[ -z "$remainder" ]]; then
          g "Usage: file <filename>"
        else
          local file_path
          file_path=$(resolve_path "$remainder")
          case "$file_path" in
            /mnt/floppy/README)   g "$remainder: ascii text" ;;
            /mnt/floppy/setup.sh) g "$remainder: commands text" ;;
            /home/mrk)            g "$remainder: directory" ;;
            /mnt/floppy)          g "$remainder: directory" ;;
            *)                    g "file: $remainder: No such file or directory" ;;
          esac
        fi
        blank
        ;;

      find)
        blank
        local find_root="$CWD"
        if [[ -n "$remainder" ]]; then
          local fa="${remainder%% -*}"
          fa="${fa%"${fa##*[![:space:]]}"}"
          [[ -n "$fa" ]] && find_root=$(resolve_path "$fa")
        fi
        case "$find_root" in
          /)
            g "."; g "./home"; g "./home/mrk"
            g "./mnt"; g "./mnt/floppy"
            g "./mnt/floppy/README"; g "./mnt/floppy/setup.sh"
            g "./tmp"
            ;;
          /home)       g "."; g "./mrk" ;;
          /home/mrk)   g "." ;;
          /mnt)        g "."; g "./floppy" ;;
          /mnt/floppy) g "."; g "./README"; g "./setup.sh" ;;
          *)           g "find: $find_root: No such file or directory" ;;
        esac
        blank
        ;;

      rm)
        blank
        if [[ -z "$remainder" ]]; then
          g "rm: missing operand"
        else
          local rm_tgt="${remainder##-* }"
          local rm_path; rm_path=$(resolve_path "$rm_tgt")
          case "$rm_path" in
            /mnt/floppy/*) g "rm: $rm_tgt: Read-only file system" ;;
            *)             g "rm: $rm_tgt: No such file or directory" ;;
          esac
        fi
        blank
        ;;

      cp|mv)
        blank; g "$verb: cannot create: Permission denied"; blank ;;

      mkdir|touch)
        blank; g "$verb: cannot create: Permission denied"; blank ;;

      chmod|chown)
        blank; g "$verb: $remainder: Operation not permitted"; blank ;;

      # ── Win condition: run the setup script ───────────────────────────────
      ./setup.sh|setup.sh)
        blank
        if [[ "$CWD" == "/mnt/floppy" ]]; then
          g "Running /mnt/floppy/setup.sh..."
          sleep 0.5; blank; tui_cleanup; exit 0
        else
          g "soda: $verb: Command not found."
          blank
        fi
        ;;

      sh|csh|tcsh)
        blank
        local run_path; run_path=$(resolve_path "$remainder")
        if [[ "$run_path" == "/mnt/floppy/setup.sh" ]]; then
          g "Running /mnt/floppy/setup.sh..."
          sleep 0.5; blank; tui_cleanup; exit 0
        else
          g "soda: $remainder: Command not found."
          blank
        fi
        ;;

      bash)
        blank
        local run_path; run_path=$(resolve_path "$remainder")
        if [[ "$run_path" == "/mnt/floppy/setup.sh" ]]; then
          g "Running /mnt/floppy/setup.sh..."
          sleep 0.5; blank; tui_cleanup; exit 0
        else
          g "bash: $remainder: No such file or directory"
          blank
        fi
        ;;

      /mnt/floppy/setup.sh)
        blank; g "Running /mnt/floppy/setup.sh..."
        sleep 0.5; blank; tui_cleanup; exit 0
        ;;

      # ── System info ──────────────────────────────────────────────────────────
      whoami)   blank; g "mrk";  blank ;;
      hostname) blank; g "soda"; blank ;;

      id)
        blank
        g "uid=1042(mrk) gid=20(staff) groups=20(staff)"
        blank
        ;;

      uname)
        blank
        case "$remainder" in
          -a|-a\ *) g "4.3BSD soda 4.3 1 vax" ;;
          *)        g "4.3BSD" ;;
        esac
        blank
        ;;

      date)
        blank; g "Thu Oct  5 11:24:37 PDT 1989"; blank ;;

      uptime)
        blank
        g "11:24am  up 2:09,  1 user,  load average: 0.04, 0.07, 0.05"
        blank
        ;;

      df)
        blank
        g "Filesystem            kbytes    used   avail capacity  Mounted on"
        g "/dev/ra0a              98304   71420   17068    81%    /"
        g "/dev/ry0a               1440     512     928    36%    /mnt/floppy"
        blank
        ;;

      free)
        blank
        g "             total       used       free"
        g "Mem:         16384      13102       3282"
        g "Swap:        32768       1024      31744"
        blank
        ;;

      mount)
        blank
        g "/dev/ra0a on / type ufs (rw)"
        g "/dev/ry0a on /mnt/floppy type ufs (ro)"
        blank
        ;;

      ps)
        blank
        case "$remainder" in
          aux|aux\ *|-aux|-aux\ *)
            g "USER       PID %CPU %MEM   SZ  RSS TT  STAT START    TIME COMMAND"
            g "root         1  0.0  1.2   40  104 ?   IW    9:14   0:00 /etc/init"
            g "root        14  0.0  1.3   52  108 ?   IW    9:14   0:00 /etc/inetd"
            g "mrk        147  0.0  2.9  152  248 co  S     9:14   0:02 -csh (csh)"
            g "mrk        193  0.0  1.4  120  192 co  R    11:24   0:00 ps aux"
            ;;
          *)
            g "  PID TT STAT  TIME COMMAND"
            g "  147 co S     0:02 -csh (csh)"
            g "  193 co R     0:00 ps"
            ;;
        esac
        blank
        ;;

      who)
        blank; g "mrk      console      Oct  5 09:14"; blank ;;

      w)
        blank
        g "11:24am  up 2:09,  1 user,  load average: 0.04, 0.07, 0.05"
        g "User     tty      login@   idle   JCPU   PCPU  what"
        g "mrk      console  9:14am          0.10s  0.02s  w"
        blank
        ;;

      last)
        blank
        g "mrk      console                       Thu Oct  5 09:14   still logged in"
        g "mrk      console                       Wed Oct  4 14:32 - 18:03  (03:30)"
        g "mrk      console                       Tue Oct  3 10:11 - 12:45  (02:33)"
        blank
        g "wtmp begins Tue Oct  3 10:11:22 1989"
        blank
        ;;

      dmesg)
        blank
        lld "Berkeley Software Distribution  Version 4.3  (soda.csua.berkeley.edu) #1: Mon Jan  9 08:12:03 PST 1989" 0.03
        lld "real mem  = 8388608" 0.02
        lld "avail mem = 7163904" 0.02
        lld "cpu: VAX 11/780" 0.02
        lld "ra0 at uba0 csr 0154400 vec 0154, ipl 21" 0.02
        lld "ra0: RD53, size 138720 sectors" 0.02
        lld "ry0: RX50/RX33  (3.5\" HD)  disk present" 0.03
        lld "/dev/ry0a: Mounting /mnt/floppy ... done." 0.08
        blank
        ;;

      env|printenv)
        blank
        g "HOME=/home/mrk"
        g "USER=mrk"
        g "SHELL=/bin/csh"
        g "TERM=vt100"
        g "PATH=/usr/ucb:/usr/bin:/bin:/usr/local/bin:."
        g "PWD=$CWD"
        g "LOGNAME=mrk"
        g "HOST=soda"
        g "DISPLAY=:0.0"
        blank
        ;;

      history)
        blank
        g "    1  ls"
        g "    2  cd /mnt/floppy"
        g "    3  ls"
        g "    4  cat README"
        g "    5  cd"
        g "    6  logout"
        blank
        ;;

      finger)
        blank
        g "Login name: mrk                         In real life: mrk"
        g "Directory: /home/mrk                    Shell: /bin/csh"
        g "On since Oct  5 09:14:22 on console"
        g "No unread mail."
        g "No Plan."
        blank
        ;;

      cal)
        blank
        g "   October 1989      "
        g "Su Mo Tu We Th Fr Sa "
        g " 1  2  3  4  5  6  7 "
        g " 8  9 10 11 12 13 14 "
        g "15 16 17 18 19 20 21 "
        g "22 23 24 25 26 27 28 "
        g "29 30 31              "
        blank
        ;;

      which)
        blank
        if [[ -z "$remainder" ]]; then
          g "Usage: which <command>"
        else
          case "$remainder" in
            ls|cat|more|less|find|file|date|df|mount|ps|who|w|\
            last|finger|cal|which|whereis|fortune|sl|make|ping|\
            sudo|su|passwd|rm|cp|mv|mkdir|touch|chmod|chown|\
            whoami|hostname|id|uname|echo|clear)
              g "/usr/bin/$remainder" ;;
            uptime|free|dmesg|env|history|w)
              g "/usr/ucb/$remainder" ;;
            csh|sh)   g "/bin/$remainder" ;;
            bash)     g "/usr/local/bin/bash" ;;
            vi|vim)       g "/usr/bin/$remainder" ;;
            adventure)    g "/usr/games/adventure" ;;
            bc)       g "/usr/bin/bc" ;;
            printenv) g "/usr/ucb/printenv" ;;
            *)        g "$remainder: Command not found." ;;
          esac
        fi
        blank
        ;;

      whereis)
        blank
        if [[ -z "$remainder" ]]; then
          g "Usage: whereis <command>"
        else
          case "$remainder" in
            csh)  g "csh: /bin/csh /usr/man/man1/csh.1" ;;
            vi)   g "vi: /usr/bin/vi /usr/man/man1/vi.1" ;;
            ls|cat|cp|mv|rm|mkdir|chmod)
                  g "$remainder: /usr/bin/$remainder /usr/man/man1/${remainder}.1" ;;
            *)    g "$remainder:" ;;
          esac
        fi
        blank
        ;;

      # ── Utilities ────────────────────────────────────────────────────────────
      echo)
        blank; g "$remainder"; blank ;;

      bc)
        blank
        if [[ -z "$remainder" ]]; then
          dg "bc 1.01 -- arbitrary-precision arithmetic"
          blank
          while true; do
            printf '%s' "${_BG}bc> ${_R}${_G}"
            local bc_in
            IFS= read -r bc_in || break
            printf '%s' "$_R"
            bc_in="${bc_in#"${bc_in%%[![:space:]]*}"}"
            if [[ "$bc_in" == "quit" || "$bc_in" == "exit" ]]; then break; fi
            [[ -z "$bc_in" ]] && continue
            local bc_out
            bc_out=$(printf '%s\n' "$bc_in" | bc 2>&1) && g "$bc_out" || g "Parse error"
          done
        else
          local bc_out
          bc_out=$(printf '%s\n' "$remainder" | bc 2>&1) && g "$bc_out" || g "Parse error"
        fi
        blank
        ;;

      make)
        blank
        g "make: No targets specified and no makefile found.  Stop."
        blank
        ;;

      ping)
        blank; g "ping: connect: Network is unreachable"; blank ;;

      sudo)
        blank
        g "sudo: Command not found."
        blank
        ;;

      su)
        blank
        printf '%s' "${_BG}Password: ${_R}${_G}"
        local su_pw; IFS= read -rs su_pw || true
        printf '\n%s' "$_R"
        blank; g "Sorry."; blank
        ;;

      passwd)
        blank
        dg "Changing password for mrk."
        printf '%s' "${_BG}Old password: ${_R}${_G}"
        local _p1; IFS= read -rs _p1 || true; printf '\n%s' "$_R"
        printf '%s' "${_BG}New password: ${_R}${_G}"
        local _p2; IFS= read -rs _p2 || true; printf '\n%s' "$_R"
        printf '%s' "${_BG}Retype new password: ${_R}${_G}"
        local _p3; IFS= read -rs _p3 || true; printf '\n%s' "$_R"
        blank
        g "passwd: Permission denied."
        blank
        ;;

      clear|cls)
        printf '%s' "$_CLR"
        draw_screen
        tput cup "$SCREEN_HEIGHT" 0
        ;;

      # ── Easter eggs ──────────────────────────────────────────────────────────
      fortune)
        blank
        local -a F=(
          "Unix is user friendly. It's just picky about who its friends are."
          "To err is human; to really foul things up requires a computer."
          "There is no place like 127.0.0.1"
          "Unix was not designed to stop you from doing stupid things, because\nthat would also stop you from doing clever things.  -- Doug Gwyn"
          "640K ought to be enough for anybody."
          "Real programmers don't comment their code.\nIf it was hard to write, it should be hard to understand."
          "Have you tried turning it off and on again?"
        )
        local idx=$(( RANDOM % ${#F[@]} ))
        printf '%s%b%s\n' "$_G" "${F[$idx]}" "$_R"
        blank
        ;;

      sl)
        tput civis
        local cols; cols=$(tput cols)
        local -a L=(
          "        ====        ________                ___________  "
          "    _D _|  |_______/        \\__I_I_____===__|___________|"
          "     |(_)---  |   H\\________/ |   |        =|___ ___|   "
          "     /     |  |   H  |  |     |   |         ||_| |_||   "
          "    |      |  |   H  |__--------------------| [___] |   "
          "    | ________|___H__/__|_____/[][]~\\_______|       |   "
          "    |/ |   |-----------I_____I [][] []  D   |=======|__ "
          " __/ =| o |=-~~\\  /~~\\  /~~\\  /~~\\ ____Y___________|__ "
          "  |/-=|___|=    ||    ||    ||    |_____/~\\___/          "
          "   \\_/      \\_O=====O=====O=====O_/      \\_/            "
        )
        local lh=${#L[@]} lw=58
        for (( i=0; i<lh; i++ )); do printf '\n'; done
        printf '\033[%dA' "$lh"
        for (( x=cols; x>=-lw; x-=3 )); do
          printf '\033[s'
          for (( r=0; r<lh; r++ )); do
            printf '\033[2K\r'
            if (( x >= 0 && x < cols )); then
              printf '%*s%s%s%s' "$x" '' "$_G" "${L[$r]}" "$_R"
            elif (( x < 0 && x > -lw )); then
              printf '%s%s%s' "$_G" "${L[$r]:$(( -x ))}" "$_R"
            fi
            printf '\n'
          done
          printf '\033[u'
          sleep 0.04
        done
        tput cnorm
        printf '\033[%dB' "$lh"
        blank
        ;;

      vi|vim)
        local vi_path=""
        [[ -n "$remainder" ]] && vi_path=$(resolve_path "$remainder")
        printf '%s' "$_CLR"; draw_screen; tput cup "$SCREEN_HEIGHT" 0
        blank
        if [[ -z "$remainder" ]]; then
          for (( i=0; i<8; i++ )); do dg "~"; done
          blank
          dg "\"[No Name]\"  -- Vi 3.7  (SunOS)"
        else
          case "$vi_path" in
            /mnt/floppy/README)
              g "MRK Setup Disk  v1.0"
              g "CSUA -- Computer Science Undergraduate Association"
              g "University of California, Berkeley"
              blank
              g "Run ./setup.sh to configure your workstation."
              for (( i=0; i<3; i++ )); do dg "~"; done
              dg "\"README\" [Read only] 5 lines, 131 characters"
              ;;
            /mnt/floppy/setup.sh)
              g "#!/bin/sh"
              g "exec /usr/local/bin/mrk-install"
              for (( i=0; i<6; i++ )); do dg "~"; done
              dg "\"setup.sh\" [Read only] 2 lines, 42 characters"
              ;;
            *)
              for (( i=0; i<8; i++ )); do dg "~"; done
              dg "\"$remainder\" [New file]"
              ;;
          esac
        fi
        blank; dg "-- NORMAL --"; blank
        while true; do
          printf '%s:%s' "$_BG" "$_G"
          local vi_cmd; IFS= read -r vi_cmd || { printf '%s\n' "$_R"; tui_cleanup; exit 1; }
          printf '%s' "$_R"
          case "$vi_cmd" in
            q|q!|wq|wq!|x|Q) break ;;
            w|w\ *) dg "\"${remainder:-[No Name]}\" File is read only." ;;
            "")     ;;
            *)      dg "Unknown command: $vi_cmd" ;;
          esac
        done
        printf '%s' "$_CLR"; draw_screen; tput cup "$SCREEN_HEIGHT" 0
        blank
        ;;

      nano|emacs|pico|ed)
        blank; g "$verb: Command not found."; blank ;;

      adventure|/usr/games/adventure)
        run_adventure ;;

      # ── Help ─────────────────────────────────────────────────────────────────
      help|man)
        blank
        g "  Navigation:   ls  cd  pwd  find"
        g "  Files:        cat  more  less  file  rm  cp  mv  mkdir  touch  chmod"
        g "  System:       uname  date  uptime  df  free  mount  ps  who  w  last"
        g "                dmesg  env  whoami  hostname  id  finger  cal  history"
        g "  Lookup:       which  whereis"
        g "  Utilities:    echo  bc  clear  make  ping  su  passwd"
        g "  Fun:          fortune  sl  vi  vim  adventure"
        g "  Session:      exit  logout"
        blank
        ;;

      exit|logout|quit)
        blank
        printf '%s' "${_BG}Really logout? [y/N] ${_R}${_G}"
        local confirm; IFS= read -r confirm || true
        printf '%s' "$_R"
        case "$(printf '%s' "$confirm" | tr '[:upper:]' '[:lower:]')" in
          y|yes) blank; dg "logout"; blank; tui_cleanup; exit 1 ;;
          *)     blank; g "logout cancelled"; blank ;;
        esac
        ;;

      "")
        ;;

      *)
        blank; g "soda: $verb: Command not found."; blank
        ;;

    esac
  done
}

# ── Main ─────────────────────────────────────────────────────────────────────
main() {
  boot_sequence
  tui_init
  trap 'tui_resize' WINCH
  blank
  unix_shell
}

main "$@"
